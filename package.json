{
  "name": "power-explained",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npx pagefind --site dist --output-path dist/pagefind && node scripts/generate-sitemap.js && node scripts/generate-llms-txt.mjs && node scripts/analyze-corpus.mjs --brief && node scripts/build-stats.mjs",
    "preview": "astro preview",
    "descent": "node scripts/gen-descent.mjs",
    "lint:tags": "node scripts/lint-tags.mjs",
    "analyze": "node scripts/analyze-corpus.mjs",
    "merge-map": "node scripts/merge-map.mjs --json && node scripts/gen-merge-map-doc.mjs",
    "test:metrics": "node scripts/test-corpus-metrics.mjs",
    "compile:plateau": "node scripts/compile-plateau.mjs"
  },
  "dependencies": {
    "@shoelace-style/shoelace": "^2.20.1",
    "astro": "^6.2.1",
    "js-yaml": "^4.1.1"
  }
}
