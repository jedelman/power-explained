---
import Base from '../../layouts/Base.astro'
import { SERIES } from '../../lib/articles.js'

const sid = 'series-iv'
const series = SERIES.find(s => s.id === sid)
const intro = ["The first three series build their argument from thinkers close to capitalism's centers. This series relocates the analysis.", "Seen from the colony, the plantation, the dam project, the occupied territory — the commons looks different, the struggle for it is more costly, and it's further advanced."]
const pullQuote = 'The people capitalism classified as outside the human built the most durable commons traditions we have. Built them under conditions explicitly designed to prevent that. Built them anyway.'
const descs = ["Cedric Robinson: capitalism wasn't color-blind and then stained by racism. Race was baked in from day one.", 'Walter Rodney: Africa was not underdeveloped. It was developed — into poverty. Deliberately, systematically.', "Frantz Fanon: colonialism produces a particular kind of human being — and requires that person's cooperation in their own subjection.", 'Achille Mbembe: not the power to manage life, but the power to decide who is exposed to death.', "Arundhati Roy reports from the enclosures while they're happening — and the communities building commons anyway, under eviction orders.", "Öcalan from Kurdistan, Bookchin from Vermont, arriving at the same conclusion: the future is communal and decentralized or it won't exist."]
---

<Base title={`${series.label} — Power Explained`} description={intro[0]} seriesTag="Series">
  <div class="series-hero">
    <div class="series-hero-inner">
      <p class="series-eyebrow">{series.label}</p>
      {intro.map((g, i) => <p class="series-intro" set:html={g} />)}
      <blockquote class="series-pull">
        <p set:html={pullQuote} />
      </blockquote>
    </div>
  </div>

  <div class="series-body">
    <ol class="piece-list">
      {series.pieces.map((piece, i) => (
        <li class="piece-item">
          <span class="piece-num">{piece.num}</span>
          <div class="piece-detail">
            <a href={piece.url} class="piece-title">{piece.title}</a>
            {descs[i] && <p class="piece-desc">{descs[i]}</p>}
          </div>
        </li>
      ))}
    </ol>
  </div>
</Base>

<style>
  .series-hero {
    background: var(--ink); color: var(--paper);
    padding: clamp(3.5rem,9vw,7rem) var(--gutter);
  }
  .series-hero-inner { max-width: var(--max); margin: 0 auto; }
  .series-eyebrow {
    font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em;
    text-transform: uppercase; opacity: 0.45; margin-bottom: 1.25rem;
  }
  .series-intro {
    font-size: clamp(1.05rem,2vw,1.2rem); line-height: 1.65; max-width: 68ch;
    margin-top: 1rem;
  }
  .series-pull {
    border-left: 2px solid var(--red); margin: 2.5rem 0 0;
    padding-left: 1.5rem; max-width: 52ch;
  }
  .series-pull p {
    font-family: var(--display); font-size: clamp(1.1rem,2.2vw,1.35rem);
    font-style: italic; font-weight: 600; line-height: 1.5;
  }
  .series-body { max-width: var(--max); margin: 0 auto; padding: clamp(3rem,7vw,5rem) var(--gutter); }
  .piece-list { list-style: none; margin: 0; padding: 0; }
  .piece-item {
    display: grid; grid-template-columns: 2.5rem 1fr; gap: 0 1.5rem;
    padding: 1.75rem 0; border-bottom: 1px solid var(--rule); align-items: start;
  }
  .piece-num {
    font-family: var(--mono); font-size: 0.65rem; font-weight: 700;
    color: rgba(var(--ink-rgb),0.3); padding-top: 0.2rem;
  }
  .piece-title {
    display: block; font-family: var(--display); font-size: clamp(1rem,2vw,1.2rem);
    font-weight: 600; line-height: 1.3; color: var(--ink);
    text-decoration: none; margin-bottom: 0.5rem;
    border-bottom: 1px solid transparent; transition: border-color 0.15s;
  }
  .piece-title:hover { border-bottom-color: var(--red); }
  .piece-desc {
    font-family: var(--body); font-size: 0.95rem; line-height: 1.6;
    color: rgba(var(--ink-rgb),0.7);
  }
</style>
