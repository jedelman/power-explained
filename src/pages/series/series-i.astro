---
import Base from '../../layouts/Base.astro'
import { SERIES } from '../../lib/articles.js'

const sid = 'series-i'
const series = SERIES.find(s => s.id === sid)
const intro = ['The basic argument. Hardin was wrong. The commons works. And enclosure requires constant enforcement.', "The way cities collect information, make decisions, and distribute resources isn't broken. It's working exactly as designed."]
const pullQuote = 'The commons is not a failure mode. It is a governance form — one that works, under conditions that can be described and replicated, and that keeps getting enclosed.'
const descs = ['The template most cities run on was designed for a world of scarce information flowing upward. That world no longer exists — but the template remains.', "Your city doesn't know what you know. The information that would make it work never makes it into the system.", 'When you show up to participate, someone else captures the value.', 'Two approaches to a broken street. One makes information disappear. The other makes it compound.', "More data didn't fix anything. Why open data is necessary but not sufficient.", 'Thousands of people, no boss, no central plan — and they built the software that runs the internet.', "Mutual aid isn't charity. It isn't crisis response. It's an infrastructure."]
---

<Base title={`${series.label} — Power Explained`} description={intro[0]} seriesTag="Series">
  <div class="series-hero">
    <div class="series-hero-inner">
      <p class="series-eyebrow">{series.label}</p>
      {intro.map((g, i) => <p class="series-intro" set:html={g} />)}
      <blockquote class="series-pull">
        <p set:html={pullQuote} />
      </blockquote>
    </div>
  </div>

  <div class="series-body">
    <ol class="piece-list">
      {series.pieces.map((piece, i) => (
        <li>
          <a href={piece.url} class="piece-item">
            <span class="piece-num">{piece.num}</span>
            <div class="piece-detail">
              <span class="piece-title">{piece.title}</span>
              {descs[i] && <p class="piece-desc">{descs[i]}</p>}
            </div>
          </a>
        </li>
      ))}
    </ol>
  </div>
</Base>

<style>
  .series-hero {
    background: var(--ink); color: var(--paper);
    padding: clamp(3.5rem,9vw,7rem) var(--gutter);
  }
  .series-hero-inner { max-width: var(--max); margin: 0 auto; }
  .series-eyebrow {
    font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em;
    text-transform: uppercase; opacity: 0.45; margin-bottom: 1.25rem;
  }
  .series-intro {
    font-size: clamp(1.05rem,2vw,1.2rem); line-height: 1.65; max-width: 68ch;
    margin-top: 1rem;
  }
  .series-pull {
    border-left: 2px solid var(--red); margin: 2.5rem 0 0;
    padding-left: 1.5rem; max-width: 52ch;
  }
  .series-pull p {
    font-family: var(--display); font-size: clamp(1.1rem,2.2vw,1.35rem);
    font-style: italic; font-weight: 600; line-height: 1.5;
  }
  .series-body { max-width: var(--max); margin: 0 auto; padding: clamp(3rem,7vw,5rem) var(--gutter); }
  .piece-list { list-style: none; margin: 0; padding: 0; }
  .piece-item {
    display: grid; grid-template-columns: 2.5rem 1fr; gap: 0 1.5rem;
    padding: 1.5rem; align-items: start;
    border: 1px solid var(--rule); border-radius: 2px;
    text-decoration: none; color: inherit;
    transition: border-color 0.15s, background 0.15s;
    margin-bottom: 0.75rem;
  }
  .piece-item:hover {
    border-color: var(--red);
    background: var(--paper-mid);
  }
  .piece-num {
    font-family: var(--mono); font-size: 0.65rem; font-weight: 700;
    color: rgba(var(--ink-rgb),0.3); padding-top: 0.25rem;
  }
  .piece-title {
    display: block; font-family: var(--display); font-size: clamp(1rem,2vw,1.2rem);
    font-weight: 600; line-height: 1.3; color: var(--ink);
    margin-bottom: 0.4rem;
  }
  .piece-desc {
    font-family: var(--body); font-size: 0.95rem; line-height: 1.6;
    color: rgba(var(--ink-rgb),0.7);
  }
</style>
