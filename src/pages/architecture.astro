---
const title = "Book Architecture — How to Become a Wizard and Save the World"
const description = "The full architectural score for the book: 24 existing chapters + 6 new initiatory chapters, braided across two movements. Argument and initiation interwoven."
const canonical = "https://power-explained.jason-edelman.org/architecture"
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="Power Explained" />
  <meta property="og:image" content="https://power-explained.jason-edelman.org/og-image.png" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    html, body, #root { width:100%; height:100%; overflow:hidden; background:#0e0c08; }
  </style>
</head>
<body>
  <div id="root"></div>
  <script type="module">
    import { createElement, useState } from 'https://esm.sh/react@18';
    import { createRoot } from 'https://esm.sh/react-dom@18/client';

    // ── Palette ────────────────────────────────────────────────────
    const C = {
      bg:"#0e0c08",surface:"#161410",border:"#2a2218",borderHi:"#4a3828",
      ink:"#e8d8b0",muted:"#7a6848",dim:"#3a2e1e",
      red:"#c0392b",amber:"#c8960a",green:"#2d6a40",
      blue:"#2a5a8a",purple:"#5a2a7a",teal:"#1a6a6a",rust:"#8a4a18",
    };
    const MOVE_COLS = {
      argument:"#3a6a9a",initiation:"#5a3a7a",mythopoetic:"#7a3a2a",
      interlude:"#2a6a4a",centaur:"#6a5a2a",epilogue:"#3a5a3a",
    };
    const ROWS = [
      {key:"movement",label:"Movement",color:"#8a7050"},
      {key:"argument",label:"Argument",color:C.blue},
      {key:"wizard",label:"Wizard Arc",color:C.amber},
      {key:"authors",label:"Authors / Leitmotifs",color:C.purple},
      {key:"myth",label:"Myth / Grimoire",color:C.rust},
      {key:"reader",label:"Reader State",color:"#5a8a5a"},
      {key:"capacity",label:"Capacity Built",color:C.teal},
      {key:"sensory",label:"Sensory Anchor",color:"#6a5a30"},
    ];
    const CELL_W=260, LABEL_W=120, ROW_H=100, HEADER_H=72;

    const CHAPTERS = [
      {id:"epigraph",label:"Epigraph",title:"Galadriel",type:"mythopoetic",color:"#2a3a4a",energyH:0.4,cells:{movement:"Threshold. Before the argument begins, the grief arrives. The world is changed. The reader already knows.",argument:"None. The epigraph does not argue. It resonates. It names the felt sense the reader carries into the first page.",wizard:"Galadriel is already the Port of Shamans: the oldest figure, the one who remembers what was.",authors:"Tolkien ★ — the mythopoetic register established. Elvish beneath English: sense culture beneath symbolic.",myth:"TOLKIEN'S GALADRIEL: The one who was there before the enclosure. The grief is accurate perception.",reader:"The reader pauses. Something in them is already named.",capacity:"Pre-capacity: the book's promise made in feeling before argument.",sensory:"The smell of something old. Water. Light that means: this was here before you."}},
      {id:"prologue",label:"Prologue",title:"Look Up",type:"argument",color:C.blue,energyH:0.75,cells:{movement:"I — DIAGNOSIS. The reader's wound named. The disconnected misfortunes revealed as one system. Then: the night herons.",argument:"These don't feel connected. They are connected. Hegemony as operating system: invisible until it crashes.",wizard:"Jason watching the herons, telling them he loves them — that is already the practice.",authors:"Gramsci ★ (subterranean) — common sense appears before its name.",myth:"THE NIGHT HERON: Returns every spring. Knows about the road. The commons is what keeps returning.",reader:"Entry wound: I feel this. I didn't know it was connected.",capacity:"Pre-capacity: the reader learns to look up.",sensory:"The red eye. The white plumes. Absolute patience. A bird built for stillness."}},
      {id:"ch1",label:"Ch. 1",title:"Some Days It Costs Too Much",type:"argument",color:C.blue,energyH:0.82,cells:{movement:"I — DIAGNOSIS. The body on the road. Eight feet down: someone's kitchen floor.",argument:"Hampton/Brambleton: designed for a body that weighs two tons. The pedestrian infrastructure IS the argument.",wizard:"Rage as perception. The body reading the terrain correctly before the mind has language for it.",authors:"Gramsci ★ (named) — common sense, war of position.",myth:"THE KITCHEN FLOOR: Eight feet down. The ruin is geological. The foundation is literally under your feet.",reader:"Physical. The reader's body remembers its own versions of this crossing.",capacity:"NAME (partial): the system is functioning as designed.",sensory:"Subsonic rumble of truck traffic felt in the bones. The specific heaviness before the curb."}},
      {id:"ch2",label:"Ch. 2",title:"They're Sprinkling Us In",type:"argument",color:C.blue,energyH:0.7,cells:{movement:"I — DIAGNOSIS. The meeting. The three minutes at the mic. The armor made from your participation.",argument:"Legitimacy as raw material. Capture vs. corruption. The system absorbed your participation.",wizard:"The wizard knows the difference between leverage and capture before entering the room.",authors:"Gramsci ↩ — hegemony applied to the meeting room.",myth:"THE MEETING ROOM: Underground entrance — where you learn what capture feels like.",reader:"Recognition: I have done this. The parking ticket. The three minutes.",capacity:"NAME: I can identify capture.",sensory:"Uncomfortable chair. Forty-five minutes of procedural business. The drive home."}},
      {id:"interlude-bcn",label:"Interlude",title:"Barcelona",type:"interlude",color:C.green,energyH:0.65,cells:{movement:"BREATH. After two chapters of diagnosis, a Tuesday evening that is just a Tuesday evening.",argument:"The infrastructure was changed, the space was returned. The superblock and the water crisis: same question at different scales.",wizard:"The man on the bicycle with the sound system: first wizard figure, unnamed. Nobody asked him to.",authors:"Abram ★ (latent) — the street as animate landscape.",myth:"THE BICYCLE WIZARD: Arizmendi avant la lettre. The ease of knowing life goes on even if yours doesn't.",reader:"The body unclenches slightly. Barcelona is proof. Not a utopia — a Tuesday.",capacity:"READ (first glimpse): the city as text.",sensory:"Salsa from a bicycle. The smell of the sea fading. Something cold and sweet. Just a Tuesday."}},
      {id:"ch3",label:"Ch. 3",title:"The Cook",type:"argument",color:C.blue,energyH:0.78,cells:{movement:"I — DIAGNOSIS. The commons is real. The typhoon. The cook written into governance.",argument:"The Zanjera: governance that works. Hardin demolished. Ostrom's eight principles.",wizard:"The cook as the wizard's first institutional form: care written into governance.",authors:"Ostrom ★ — the cartographer of the commons. Hardin ★ (as ruin).",myth:"THE COOK: The governance structure that writes feeding into law.",reader:"You know this is right — not as argument, as feeling. The book earns its first somatic assent.",capacity:"BUILD (first glimpse): governance that encodes care.",sensory:"Bamboo and stone. The typhoon. Heavy communal labor. Someone preparing meals."}},
      {id:"interlude-wa",label:"Interlude",title:"Counter-Hegemony Without the Word",type:"initiation",color:C.purple,energyH:0.9,cells:{movement:"II — INITIATION (first). The children and the deer. The body older than itself.",argument:"You cannot protect what you cannot imagine losing. The emotional and bodily argument differs in kind, not degree.",wizard:"Jason as wizard-in-training: building conditions for something to arrive that cannot be forced.",authors:"Abram ★ (full) — The Spell of the Sensuous. Tom Brown Jr. ★ — the stalking practice.",myth:"THE STALKING CHILDREN: The deer showed up and they became something older than themselves.",reader:"First initiatory moment. Something in the reader's body recognizes the stalking crouch.",capacity:"ENTER (first): the body as entrance.",sensory:"Old-growth forest. The quality of silence that isn't silence. A deer at the edge of the clearing."}},
      {id:"ch4",label:"Ch. 4",title:"Nobody Asked Him To",type:"argument",color:C.blue,energyH:0.85,cells:{movement:"I — DIAGNOSIS. The commons works at scale. Mondragón. Champlain. Cooperation Jackson.",argument:"Nobody asked him to. The wizard who builds without holding a position. The commons settlements working globally.",wizard:"Arizmendi: the book's first named wizard. Arrived by bike with one eye. Never held a position.",authors:"Arizmendi ★ — wizard figure. Ostrom ↩. Graeber ★ (latent).",myth:"THE PRIEST ON THE BIKE: Blessed the foundation stone and stepped back. This is how the wizard operates.",reader:"Expansion: it works. The reader has proof before they have the full theory.",capacity:"BUILD: the cooperative as learnable, repeatable design.",sensory:"The Basque mountains in February 1941. A paraffin stove. A foundation stone blessed."}},
      {id:"new1",label:"New Ch.",title:"The Goetia of Capital",type:"initiation",color:C.purple,energyH:0.88,isNew:true,cells:{movement:"II — INITIATION. The naming practice. You give something a name, a seal — and suddenly you can work with it.",argument:"Conscientization as grimoire practice. Freire: the word breaks the silence. The word is the seal.",wizard:"The wizard's first tool: naming. Merlin doesn't fight — he sees. The name is the first move.",authors:"Freire ★ — conscientization. The AI engineers' Lesser Key of Solomon. Graeber ↩ — debt named.",myth:"THE LESSER KEY: Each demon has a specific domain, a specific weakness, a specific use. The Goetia of Capital.",reader:"Exercise: the reader names three structures they have been silent about. Active participation.",capacity:"NAME (full): I can name the invisible structures. I am now dangerous.",sensory:"A medieval grimoire, its margins annotated. The specific release when you find the word."}},
      {id:"ch5",label:"Ch. 5",title:"The Smile",type:"argument",color:C.blue,energyH:0.92,cells:{movement:"I — DIAGNOSIS. Luxemburg's smile. The math of capitalism. The frontier that never disappears.",argument:"Accumulation cannot sustain itself from its own interior. The outside is structural necessity.",wizard:"Luxemburg: the wizard who sees from inside the prison what those outside cannot.",authors:"Luxemburg ★ — the smile, the prison letters, the mathematical argument.",myth:"THE SMILING PRISONER: 1914. Already knows the verdict. The smile as clear perception, not resignation.",reader:"The reader recognizes the smile. They have worn it. Named now as political clarity.",capacity:"READ: I can read the system's logic. I know where the frontier will advance next.",sensory:"A Frankfurt courtroom. The light in a room where the decision has already been made."}},
      {id:"ch6",label:"Ch. 6",title:"The Shrug",type:"argument",color:C.blue,energyH:0.8,cells:{movement:"I — DIAGNOSIS. Where Jason stands. The shrug as embodied hegemony. Race is in the mechanism.",argument:"Position stated. Racial capitalism: race is constitutive, not accidental.",wizard:"The body is the map. The wizard's first task: recognizing the shrug in yourself.",authors:"Robinson ★ — Black Marxism. Racial capitalism as geological, not accidental.",myth:"THE SHRUG: A physical vocabulary of diminished expectation, learned and then taught.",reader:"Discomfort. Where are you standing? The reader is asked to locate themselves.",capacity:"NAME: I can identify where I have been taught to shrug.",sensory:"Richmond VA. The turned shoulder. A child learning what is possible."}},
      {id:"ch7",label:"Ch. 7",title:"He Wanted His Nerves Back",type:"argument",color:C.blue,energyH:0.85,cells:{movement:"I — DIAGNOSIS. Fanon at Blida-Joinville. The torturer and the tortured in the same building.",argument:"The pathologies of the torturer require the pathologies of the tortured. Diagnosis: a social system.",wizard:"Fanon as physician-wizard: treating both sides. Seeing the system producing both wounds.",authors:"Fanon ★ — The Wretched of the Earth.",myth:"THE FRENCH OFFICER: He wants his nerves back so he can return to his work.",reader:"The reader considers which side of this they have been on.",capacity:"READ: I can see the colonial structure operating in both directions.",sensory:"Blida-Joinville. A clinical consultation room. Professional detachment."}},
      {id:"ch8",label:"Ch. 8",title:"No Name for It",type:"argument",color:C.blue,energyH:0.78,cells:{movement:"I — DIAGNOSIS. The gap. Crenshaw. Wynter: the overrepresentation of Man.",argument:"The gap is not a crack in an otherwise coherent system. It is the system working as designed.",wizard:"Wynter: maps the epistemic structure that decides which experiences count.",authors:"Crenshaw ★ — intersectionality. Wynter ★ — overrepresentation of Man.",myth:"THE GAP: Where you fall through the categories. The underground entrance that opens involuntarily.",reader:"The reader thinks of their own gap — something the available language couldn't hold.",capacity:"NAME: I can see the gaps in the framework.",sensory:"The GM courtroom, 1976. The silence that is not peace."}},
      {id:"new2",label:"New Ch.",title:"The Orgone Accumulator",type:"initiation",color:C.purple,energyH:0.87,isNew:true,cells:{movement:"II — INITIATION. Reich and the body. The armored body as fascism's substrate.",argument:"Mass psychology of fascism: thwarted longing redirected into submission. The helplessness is manufactured.",wizard:"The wizard's body is the proof. Plotkin, Prechtel, Abram, Brown — all describing Reich from different directions.",authors:"Reich ★ — Mass Psychology of Fascism. Plotkin ★ — Soulcraft. Body and soul as the same project.",myth:"THE ORGONE ACCUMULATOR: Collects the life force the fascist system is draining. The body is where politics lives first.",reader:"The reader locates where they are armored. A practice offered — not described, performed.",capacity:"ENTER: The body as entrance. The unarmoring as underground entrance.",sensory:"A body aware of where it is held. The quality of attention when the armor softens."}},
      {id:"ch9",label:"Ch. 9",title:"He Built It Anyway",type:"argument",color:C.blue,energyH:0.95,cells:{movement:"I — DIAGNOSIS. Turin 1920. The factory councils. Gramsci's question: why did the terrain not hold?",argument:"Hegemony: the mechanism by which the plains feel natural. War of position: trails, not roads.",wizard:"Gramsci in prison IS the wizard archetype: the prisoner who writes the map. The hermit's cave as prison cell.",authors:"Gramsci ↩ — first full theoretical treatment. The central leitmotif reaches its first climax.",myth:"GRAMSCI AS MYTH: Not Prometheus — the World Card. Dancing inside the wreath. The notebooks are the grimoire.",reader:"The reader understands why every meeting fails in the same way. And what building the terrain requires.",capacity:"BUILD: I understand positions and why they must be built before the moment arrives.",sensory:"Turin, September 1920. A factory floor without managers. Exercise notebooks. Eleven years."}},
      {id:"ch10",label:"Ch. 10",title:"The Birds She Fed Through the Bars",type:"argument",color:C.blue,energyH:0.88,cells:{movement:"I — DIAGNOSIS. Luxemburg in Breslau, 1918. The birds named through bars. Singularity as freedom's condition.",argument:"Freedom is always and exclusively freedom for the one who thinks differently. Same exclusion as Wynter.",wizard:"Luxemburg feeding birds through prison bars: attention that cannot be enclosed.",authors:"Luxemburg ↩ — the prison letters alongside the theory. Benjamin ★ (latent). Wynter ↩.",myth:"THE STARLINGS IN BRESLAU: The wizard's practice in extremis. Ferocious attention from a room you cannot leave.",reader:"The reader understands that the commons requires singularity — not despite its wildness but because of it.",capacity:"HOLD: I can hold the singular — mine and others'.",sensory:"The women's prison at Breslau. White anemones in April. Starlings in afternoon light."}},
      {id:"ch11",label:"Ch. 11",title:"The Circle in the Blizzard",type:"argument",color:C.blue,energyH:0.82,cells:{movement:"I — DIAGNOSIS. Kropotkin in Siberia. Mutual aid as evolutionary baseline.",argument:"The horses in the blizzard: no leader, distributed solution without deliberation. Competition is the special case.",wizard:"Kropotkin: went to Siberia to find the truth and found it. The wizard always goes to the field.",authors:"Kropotkin ★ — Mutual Aid. Graeber ↩ — baseline communism confirmed historically.",myth:"THE HORSES IN THE BLIZZARD: No one decided. The form emerged because the conditions required it.",reader:"Relief. The dominant narrative demolished by evidence. The reader's intuition confirmed.",capacity:"READ: I can see mutual aid where the dominant narrative sees competition.",sensory:"Siberia. The cold that requires collective solution. Horses forming circles. No leader."}},
      {id:"ch12",label:"Ch. 12",title:"This Was Made",type:"argument",color:C.blue,energyH:0.85,cells:{movement:"I — DIAGNOSIS. Roy waist-deep in the Narmada. Witness as position. The dam as enclosure in real time.",argument:"Roy names what is being drowned. The witness refuses to let the filling proceed as though people aren't there.",wizard:"Roy as wizard-witness: standing in the water. Present in the place the system is trying to erase.",authors:"Roy ★ — The Greater Common Good. The witness position made method.",myth:"THE RISING WATER: The dam keeps filling. The movement keeps naming.",reader:"The reader understands their own version of the rising water.",capacity:"NAME: I can witness. I can stand somewhere and name what is being lost.",sensory:"Winter 1999. Narmada River. Waist-deep. The specific cold of a river in winter."}},
      {id:"ch13",label:"Ch. 13",title:"We're Canceling It",type:"argument",color:C.blue,energyH:0.88,cells:{movement:"I — DIAGNOSIS. Graeber and the debt. Rolling Jubilee. The weapon turned.",argument:"Debt is a social relationship weaponized. The Jubilee is the commons' answer: the periodic clearing.",wizard:"Graeber in the library AND in Zuccotti Park — theory and practice in the same body.",authors:"Graeber ★ — Debt: The First 5,000 Years. The barter myth demolished.",myth:"THE BARTER THAT NEVER WAS: No anthropological evidence. The origin story is fiction.",reader:"The reader's own debt comes into focus as a structural relationship, not a moral failure.",capacity:"NAME: I can see debt as a designed weapon. The Rolling Jubilee as proof it can be turned.",sensory:"A Rolling Jubilee letter arriving. The moment the dread of a medical debt lifts."}},
      {id:"new3",label:"New Ch.",title:"The Angel Faces Backward",type:"initiation",color:C.purple,energyH:0.9,isNew:true,cells:{movement:"II — INITIATION. Benjamin's angel and the ruins. The shard-reading practice.",argument:"Benjamin wrote from exile, surrounded by fascism, still writing. The writing was the turning.",wizard:"Benjamin as wizard-collector: finding the shard of the old world in the debris of the new.",authors:"Benjamin ★ — Theses on History, The Arcades Project. Debord ↩ — détournement as the collector's move.",myth:"ANGEL OF HISTORY: Klee's Angelus Novus. The collector who finds the fragment and recognizes it.",reader:"Practice: the reader finds one shard from their own debris — one thing not as lost as it seemed.",capacity:"READ: I can read the capitalist imaginal against its grain. I can find the shard.",sensory:"A Berlin flea market, 1930s. The specific quality of recognition when you find what survived."}},
      {id:"ch14",label:"Ch. 14",title:"I Became the Land",type:"argument",color:C.blue,energyH:0.85,cells:{movement:"I — DIAGNOSIS. Atlantic City returns. Land as the commons beneath all other commons.",argument:"Primitive accumulation: the precondition. The land trust removes land from speculation permanently.",wizard:"Brenda Torpy: refusing the market's premise. Building governance before the land is worth fighting over.",authors:"Marx ★ (named) — primitive accumulation. Federici ↩ — enclosure as precondition.",myth:"THE LAND BENEATH: You cannot extract rent from people who own the land they live on.",reader:"The reader understands what is under everything. What was there before.",capacity:"BUILD: I understand the land trust as a form.",sensory:"Atlantic City under the medical campus. A resale covenant written into every deed."}},
      {id:"ch15",label:"Ch. 15",title:"Still Meeting",type:"argument",color:C.blue,energyH:0.8,cells:{movement:"I — DIAGNOSIS. Crown Heights on Tuesday evenings. Federici and the witch trials.",argument:"The witch trials as policy: the enclosure of care knowledge alongside the enclosure of land.",wizard:"Federici: follows the question 600 years. Finds care and land enclosed simultaneously.",authors:"Federici ★ — Caliban and the Witch. Selma James ★ — Wages for Housework.",myth:"THE WITCH TRIALS AS POLICY: Burned for usefulness. The midwife as enclosure target.",reader:"The reader recognizes their own care labor — uncompensated, invisible, foundational.",capacity:"BUILD: I can recognize care as commons infrastructure.",sensory:"Tuesday evenings in Crown Heights. The warmth of a room where food distribution happens."}},
      {id:"new4",label:"New Ch.",title:"Re-Enchanting the World",type:"initiation",color:C.purple,energyH:0.93,isNew:true,cells:{movement:"II — INITIATION. Federici and Plotkin together: re-enchantment and soul-making as the same project.",argument:"The capitalist disenchantment was a political project. Restoring the enchanted relationship is the commons' deepest work.",wizard:"Plotkin's soul encounter as the wizard's underground journey. Prechtel: the community that receives must know how to receive.",authors:"Federici ↩ — Re-Enchanting the World. Plotkin ★ — Soulcraft. Prechtel ★ — Grief and Praise.",myth:"THE ENCHANTED COMMONS: The witch was burned because she knew the land as a living presence.",reader:"First full initiatory encounter. Taken underground. Emerges with a relationship, not knowledge.",capacity:"ENTER (deep): I have been underground and returned. I know what I found there.",sensory:"An old-growth forest at night. The feeling of being watched by something older — and recognized."}},
      {id:"ch16",label:"Ch. 16",title:"Even That Part",type:"argument",color:C.blue,energyH:0.97,cells:{movement:"I → II PIVOT. Love as commons. The mycorrhizal network. The body refuses. The singularity argument approaches.",argument:"Love nourishes singularity. Simondon's pre-individual field. The GPL as détournement. Platform as enclosure of connection.",wizard:"Marsha P. Johnson at the gate of the Port. Turing: lateral cognition from every room you didn't fit in.",authors:"Hardt/Negri ★ — love as political force. Simondon ★. Baudrillard ★. Deleuze ★ (full).",myth:"LOVE AS COMMONS: The force that makes becoming possible. The mycorrhizal network as the argument's spine.",reader:"The reader is named. Their singularity given back. Something returned that the system was slowly taking.",capacity:"HOLD (full): I can hold my own singularity against the averaging pressure.",sensory:"A body in a room, quiet with something usually kept quiet. Broken glass. Laughter. A runner alone outside Cambridge."}},
      {id:"ch16b",label:"Ch. 16b",title:"The Hollow Book",type:"argument",color:C.blue,energyH:0.95,cells:{movement:"I — DIAGNOSIS (climax). The simulacrum. The Matrix re-read. You are what the system cannot train on.",argument:"Baudrillard's four stages. Basmati rice. The simulation producing conditions of its own training.",wizard:"The Wachowskis left a message in a hollowed-out book. The wizard is structurally the one who knew their representation wasn't true.",authors:"Baudrillard ↩ (climax). Wachowskis ★. Wynter ↩ (climax). Turing ↩.",myth:"THE HOLLOW BOOK: A disc of contraband software inside Simulacra and Simulation.",reader:"Strike. The reader directly addressed: you are what the system cannot train on.",capacity:"HOLD + NAME simultaneously: I am not my representation.",sensory:"A dining table becoming a set. The slight flatness after closing the app. A grain of Basmati rice."}},
      {id:"centaur",label:"Chiron",title:"The Centaur Chapter",type:"centaur",color:C.amber,energyH:0.85,cells:{movement:"META-CHAPTER. The book's form is the argument. The centaur inhabits the boundary.",argument:"Chiron chose differently. He taught medicine and music. He surrendered his immortality so Prometheus could be freed.",wizard:"THIS IS the wizard chapter. Chiron-wizard: inhabits both the cultivated and the wild. The wound is the teaching.",authors:"All leitmotifs present simultaneously. The centaur is the form that holds them all.",myth:"CHIRON: Not triumph. Release. Placed in the stars not as hero but as teacher who completed his teaching.",reader:"The reader understands the book's form as argument.",capacity:"All six capacities present. The centaur uses them in service of others' becoming.",sensory:"Mount Pelion. A cave. The accidental arrow. The choice to surrender immortality. The stars."}},
      {id:"ch17",label:"Ch. 17",title:"The Owl at the Edge",type:"initiation",color:C.purple,energyH:0.9,cells:{movement:"II — INITIATION. The tracking practice. The speaking circle. The owl.",argument:"Tracking shifts consciousness from management to reception mode. The form holds what arrives.",wizard:"The wizard's practice: attending. The boundary between attending and being attended-to becomes less clear.",authors:"Plotkin ↩ — Nature and the Human Soul. Prechtel ↩. Abram ↩.",myth:"THE OWL: He came silently and perched at the edge. The form held him. The form held the group. Both were the same form.",reader:"The reader wants to be in a speaking circle. The chapter performed its function.",capacity:"RETURN: I know how to hold the singular presence. I can build the form.",sensory:"Forest edge. An owl arriving in silence. The group holding the pause."}},
      {id:"new5",label:"New Ch.",title:"What You Bring Back",type:"initiation",color:C.purple,energyH:0.92,isNew:true,cells:{movement:"II — INITIATION. The return from the underground. Prechtel: grief and praise are the same current.",argument:"The soul encounter requires a community that knows how to receive it. The wizard's gift needs the commons.",wizard:"Prechtel: the grief-worker as wizard. The community's capacity to hold grief is its capacity to hold joy.",authors:"Prechtel ↩ — Flowering Earth (second entry). Plotkin ↩ — Nature and the Human Soul.",myth:"GRIEF AND PRAISE: The same current. The Port of Shamans: where those who have been underground find each other.",reader:"Given a practice for return: how to bring what you found underground back to your community.",capacity:"RETURN (full): I know how to return and offer what I found.",sensory:"The Port of Shamans at dawn. The salt marsh. Grief that is also praise."}},
      {id:"ch18",label:"Ch. 18",title:"You Wonderful Weird Birds",type:"argument",color:C.blue,energyH:0.93,cells:{movement:"I + II CONVERGENCE. Occupy. The mycorrhizal network fast enough to see. Everything happening simultaneously.",argument:"The general assembly. The people's mic. Poor in demands, rich in forms. The form preceded the content.",wizard:"Graeber in Zuccotti Park: theory and practice in the same body, in the same place.",authors:"Graeber ↩ (climax). Hardt/Negri ↩ — Declaration. Debord ↩ — détournement at scale.",myth:"THE PEOPLE'S MIC: The speaking circle discovered again in lower Manhattan. Pattern languages emerge when conditions are right.",reader:"The reader feels the possibility in their body. The form is available. It was available in 1920 and 2011 and now.",capacity:"All six: Name / Read / Build / Hold / Enter / Return.",sensory:"Zuccotti Park, fall 2011. The people's mic cascading outward. 900 cities simultaneously."}},
      {id:"new6",label:"New Ch.",title:"The Wizard's Walk",type:"mythopoetic",color:C.rust,energyH:0.96,isNew:true,cells:{movement:"II — INITIATION (climax). The reader takes the wizard's walk. All six capacities exercised. The book performs its argument.",argument:"The wizard does not know the future. The wizard reads the terrain. The reader is now a wizard — beginning.",wizard:"The reader IS the wizard now. You have been given the tools. This chapter is addressed directly.",authors:"All leitmotifs return simultaneously. The grimoire complete.",myth:"THE QUEST GIVER: We must become the quest giver, not the Hero. The reader receives a specific, local, possible quest.",reader:"The reader receives their quest: one specific thing, in one specific place, that only they can do.",capacity:"All six exercised in sequence: Name → Read → Build → Hold → Enter → Return.",sensory:"The map in the reader's hands. The camp at the river junction. The fire burning for years."}},
      {id:"epilogue",label:"Epilogue",title:"The Doves",type:"epilogue",color:C.green,energyH:0.7,cells:{movement:"LANDING. Doves on the ground. Years of practice. The meadow not cut. The trickle after the catastrophe.",argument:"The commons is not only what was taken. It is what is still here. The open protocols still running underneath.",wizard:"Jason's autobiography at the end: the practice, not the theory. The doves feeling the quieted body.",authors:"All leitmotifs present and quiet. The book breathes out.",myth:"THE DOVES: They don't know about the enclosure, the seventeen chapters. They are just here in the morning.",reader:"The reader closes the book knowing what they are going to do. Specifically. The Shire is enough.",capacity:"All six capacities present quietly. Available now.",sensory:"Morning. Doves close enough to touch. A meadow not cut. A body practiced enough to be trusted."}},
    ];

    function EnergyBar({value,color}){
      return createElement('div',{style:{width:"100%",height:6,background:"#1a1410",borderRadius:2,overflow:"hidden",marginTop:4}},
        createElement('div',{style:{width:`${Math.round(value*100)}%`,height:"100%",background:color,borderRadius:2,opacity:0.85}})
      );
    }

    function App(){
      const [active,setActive]=useState(null);
      const [hiddenRows,setHiddenRows]=useState({});
      const [showNew,setShowNew]=useState(true);
      const toggleRow=k=>setHiddenRows(h=>({...h,[k]:!h[k]}));
      const visRows=ROWS.filter(r=>!hiddenRows[r.key]);
      const visChaps=showNew?CHAPTERS:CHAPTERS.filter(c=>!c.isNew);
      const activeC=CHAPTERS.find(c=>c.id===active);

      return createElement('div',{style:{background:C.bg,color:C.ink,fontFamily:"'Georgia',serif",height:"100vh",display:"flex",flexDirection:"column",overflow:"hidden",userSelect:"none"}},

        // Top bar
        createElement('div',{style:{background:C.surface,borderBottom:`1px solid ${C.border}`,padding:"10px 14px 8px",flexShrink:0}},
          createElement('div',{style:{display:"flex",alignItems:"center",gap:10,marginBottom:8,flexWrap:"wrap"}},
            createElement('a',{href:"/book",style:{fontFamily:"monospace",fontSize:8,color:C.muted,letterSpacing:"0.12em",textDecoration:"none",textTransform:"uppercase"}},"← Book"),
            createElement('span',{style:{color:C.dim}},'|'),
            createElement('span',{style:{fontSize:11,color:C.muted,fontStyle:"italic"}},"How to Become a Wizard and Save the World — Architectural Score"),
            createElement('span',{style:{color:C.dim}},'|'),
            createElement('span',{style:{fontFamily:"monospace",fontSize:8,color:C.muted}},`${visChaps.length} movements`),
            createElement('button',{onClick:()=>setShowNew(v=>!v),style:{marginLeft:"auto",fontFamily:"monospace",fontSize:8,letterSpacing:"0.1em",textTransform:"uppercase",padding:"3px 9px",border:`1px solid ${showNew?C.purple:C.dim}`,background:showNew?C.purple+"33":"transparent",color:showNew?"#c0a0e0":C.muted,cursor:"pointer",borderRadius:2}},showNew?"✦ New chapters on":"✦ New chapters off")
          ),
          createElement('div',{style:{display:"flex",gap:4,flexWrap:"wrap"}},
            ...ROWS.map(r=>{
              const muted=hiddenRows[r.key];
              return createElement('button',{key:r.key,onClick:()=>toggleRow(r.key),style:{fontFamily:"monospace",fontSize:8,letterSpacing:"0.08em",textTransform:"uppercase",padding:"2px 8px",border:`1px solid ${muted?C.dim:r.color+"88"}`,background:muted?"transparent":r.color+"18",color:muted?C.dim:r.color,cursor:"pointer",borderRadius:2}},r.label);
            })
          )
        ),

        // Arrangement
        createElement('div',{style:{display:"flex",flex:1,overflow:"hidden"}},
          // Row labels
          createElement('div',{style:{width:LABEL_W,flexShrink:0,background:C.surface,borderRight:`1px solid ${C.border}`,display:"flex",flexDirection:"column"}},
            createElement('div',{style:{height:HEADER_H,borderBottom:`1px solid ${C.border}`,flexShrink:0}}),
            ...visRows.map(r=>createElement('div',{key:r.key,style:{height:ROW_H,borderBottom:`1px solid ${C.border}`,display:"flex",alignItems:"center",padding:"0 10px",gap:6,flexShrink:0}},
              createElement('div',{style:{width:2,height:22,borderRadius:1,background:r.color,flexShrink:0}}),
              createElement('span',{style:{fontSize:9,color:r.color,textTransform:"uppercase",letterSpacing:"0.09em",lineHeight:1.3}},r.label)
            ))
          ),
          // Scrollable tracks
          createElement('div',{style:{flex:1,overflowX:"auto",overflowY:"hidden",WebkitOverflowScrolling:"touch"}},
            createElement('div',{style:{display:"flex",flexDirection:"column",width:visChaps.length*CELL_W}},
              // Header
              createElement('div',{style:{display:"flex",height:HEADER_H,borderBottom:`1px solid ${C.border}`,flexShrink:0}},
                ...visChaps.map(ch=>{
                  const isActive=active===ch.id;
                  return createElement('div',{key:ch.id,onClick:()=>setActive(isActive?null:ch.id),style:{width:CELL_W,flexShrink:0,borderRight:`1px solid ${C.border}`,padding:"7px 10px 5px",cursor:"pointer",background:isActive?ch.color+"28":"transparent",borderTop:`2px solid ${isActive?ch.color:"transparent"}`,display:"flex",flexDirection:"column",gap:3,position:"relative"}},
                    ch.isNew&&createElement('div',{style:{position:"absolute",top:4,right:5,fontFamily:"monospace",fontSize:7,color:C.purple,letterSpacing:"0.1em"}},"✦ NEW"),
                    createElement('div',{style:{display:"flex",alignItems:"center",gap:6}},
                      createElement('span',{style:{fontSize:9,color:ch.color,fontWeight:"bold",letterSpacing:"0.1em",flexShrink:0}},ch.label),
                      createElement('span',{style:{fontSize:9,color:C.muted,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",flex:1}},ch.title)
                    ),
                    createElement(EnergyBar,{value:ch.energyH,color:ch.color}),
                    createElement('span',{style:{fontFamily:"monospace",fontSize:7,color:MOVE_COLS[ch.type]||C.muted,letterSpacing:"0.08em",textTransform:"uppercase"}},ch.type)
                  );
                })
              ),
              // Content rows
              ...visRows.map(row=>createElement('div',{key:row.key,style:{display:"flex",height:ROW_H,borderBottom:`1px solid ${C.border}`,flexShrink:0}},
                ...visChaps.map(ch=>{
                  const isActive=active===ch.id;
                  const isDim=active&&!isActive;
                  return createElement('div',{key:ch.id,onClick:()=>setActive(isActive?null:ch.id),style:{width:CELL_W,flexShrink:0,borderRight:`1px solid ${C.border}`,padding:"7px 10px",cursor:"pointer",background:isActive?row.color+"14":C.surface,opacity:isDim?0.18:1,transition:"opacity 0.15s, background 0.15s",overflow:"hidden",position:"relative"}},
                    createElement('div',{style:{position:"absolute",top:0,left:0,right:0,height:1,background:isActive?row.color:row.color+"30"}}),
                    createElement('p',{style:{margin:0,fontSize:10,lineHeight:1.55,color:isActive?C.ink:C.muted,whiteSpace:"pre-line",overflow:"hidden",display:"-webkit-box",WebkitLineClamp:5,WebkitBoxOrient:"vertical"}},ch.cells[row.key])
                  );
                })
              ))
            )
          )
        ),

        // Detail drawer
        createElement('div',{style:{background:C.surface,borderTop:`2px solid ${activeC?activeC.color:C.border}`,height:activeC?220:34,transition:"height 0.2s ease, border-color 0.15s",flexShrink:0,overflow:"hidden",display:"flex",flexDirection:"column"}},
          createElement('div',{onClick:()=>setActive(null),style:{height:34,display:"flex",alignItems:"center",padding:"0 14px",cursor:activeC?"pointer":"default",gap:8,flexShrink:0}},
            activeC
              ?[
                  activeC.isNew&&createElement('span',{key:"new",style:{fontFamily:"monospace",fontSize:8,color:C.purple}},"✦ NEW"),
                  createElement('span',{key:"lbl",style:{fontFamily:"monospace",fontSize:9,fontWeight:"bold",color:activeC.color,letterSpacing:"0.1em"}},activeC.label),
                  createElement('span',{key:"ttl",style:{color:C.ink,fontSize:11,fontStyle:"italic"}},activeC.title),
                  createElement('span',{key:"typ",style:{fontFamily:"monospace",fontSize:8,color:MOVE_COLS[activeC.type],textTransform:"uppercase",letterSpacing:"0.08em"}},activeC.type),
                  createElement('span',{key:"x",style:{color:C.dim,fontSize:9,marginLeft:"auto"}},"✕ close"),
                ]
              :createElement('span',{style:{fontFamily:"monospace",fontSize:8,color:C.dim,letterSpacing:"0.1em",textTransform:"uppercase"}},"tap any movement to expand")
          ),
          activeC&&createElement('div',{style:{flex:1,display:"flex",overflowX:"auto",overflowY:"hidden",WebkitOverflowScrolling:"touch"}},
            ...visRows.map(row=>createElement('div',{key:row.key,style:{minWidth:210,maxWidth:280,padding:"8px 14px 12px",borderRight:`1px solid ${C.border}`,flexShrink:0,overflowY:"auto"}},
              createElement('div',{style:{fontFamily:"monospace",fontSize:7,letterSpacing:"0.15em",textTransform:"uppercase",color:row.color,marginBottom:6}},row.label),
              createElement('div',{style:{fontSize:11,lineHeight:1.65,color:"#c8b890",whiteSpace:"pre-line"}},activeC.cells[row.key])
            ))
          )
        )
      );
    }

    createRoot(document.getElementById('root')).render(createElement(App));
  </script>
</body>
</html>
