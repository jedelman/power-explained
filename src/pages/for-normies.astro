---
import Base from '../layouts/Base.astro'
---
<Base title="Start Here — Power Explained" description="Start here if you want the basic argument without any assumed background.">
  <div class="hero">
    <div class="hero-inner">
      <h1>Power Explained — For Everyone</h1>
      <p class="hero-dek">You already know something is wrong. This is the plainest version of the argument — why cities fail, why costs keep rising, what enclosure actually means, and what people have built instead.</p>
    </div>
  </div>
  <div class="article-wrap">
    <ol class="piece-list">
      <li>
        <a href="/for-normies" class="piece-item">
          <div class="piece-detail">
            <span class="piece-title">Start Here</span>
            <p class="piece-desc">The most direct path through the argument.</p>
          </div>
        </a>
      </li>
      <li>
        <a href="/series/series-i" class="piece-item">
          <div class="piece-detail">
            <span class="piece-title">Series I — The Basic Architecture</span>
            <p class="piece-desc">Seven pieces on why the system breaks and what works instead.</p>
          </div>
        </a>
      </li>
    </ol>
  </div>
</Base>

<style>
  .piece-list { list-style: none; padding: 0; }
  .piece-item {
    display: block; padding: 1.5rem;
    border: 1px solid var(--rule); border-radius: 2px;
    text-decoration: none; color: inherit;
    transition: border-color 0.15s, background 0.15s;
    margin-bottom: 0.75rem;
  }
  .piece-item:hover { border-color: var(--red); background: var(--paper-mid); }
  .piece-title { display: block; font-family: var(--display); font-size: 1.1rem; font-weight: 600; margin-bottom: 0.4rem; }
  .piece-desc { font-family: var(--body); font-size: 0.95rem; line-height: 1.6; color: rgba(var(--ink-rgb),.7); }
</style>
