---
import Base from '../layouts/Base.astro'
---
<Base title="Page Not Found — Power Explained" description="This page doesn't exist.">
  <div class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">404</p>
      <h1>Page Not Found</h1>
      <p class="hero-dek">This URL doesn't exist. Maybe a link is broken, or the page moved.</p>
    </div>
  </div>
  <div class="article-wrap" style="text-align:center; padding-top: 3rem;">
    <a href="/" class="cta-link">← Home</a>
    <span style="margin: 0 1rem; opacity:0.3">·</span>
    <a href="/series/series-i" class="cta-link">Start reading →</a>
  </div>
</Base>

<style>
  .hero-eyebrow {
    font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.15em;
    text-transform: uppercase; opacity: 0.4; margin-bottom: 1rem;
  }
  .cta-link {
    font-family: var(--mono); font-size: 0.75rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--red); text-decoration: none;
  }
  .cta-link:hover { text-decoration: underline; }
</style>
