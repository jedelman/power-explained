  // New boundary-zone features
  const BOUNDARY_ZONES = [
    {
      x:820, y:1680,
      label:'The Salt Marsh',
      desc:'Where the Care Forest meets the Ocean of Consciousness. Neither fully land nor fully sea. Grief-work territory. Hospice. Liminal practice. The most generative edge on the map. Neither the forest\'s rules nor the ocean\'s apply here fully.',
