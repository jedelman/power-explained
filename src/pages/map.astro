  const INFRA_CAMPS = [
    {
      x:560, y:800,
      label:'The Junction Camp',
      desc:'Where the Mutual Aid Trail meets the river, before the Market crossing. A fire pit. Knowledge of which reeds are edible. Someone who will teach you to navigate the river if you ask. Been here for years. Nobody owns it. This is Graeber in Zuccotti Park. This is Crown Heights on Tuesday evenings.',
