  const INFRA_CHECKPOINTS = [
    {
      x:960, y:700,
      label:'The River Crossing Toll',
      desc:'Where the Toll Road crosses the River of Mutual Aid. The unavoidable bottleneck if you take the road. The Market is 200 meters upstream. The toll: legibility. You must be the kind of person the Market can process.',
