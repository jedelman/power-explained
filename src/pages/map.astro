  function buildInfraLayer(RW, RH) {
    const c=document.createElement('canvas'); c.width=RW; c.height=RH;
    const ctx2=c.getContext('2d');
    const sx=RW/MW, sy=RH/MH;

    // Toll roads — dark red, solid, with toll markers
    for (const road of INFRA_TOLL_ROADS) {
      ctx2.save();
      ctx2.strokeStyle='#8a2a10'; ctx2.lineWidth=2.5;
      ctx2.setLineDash([]); ctx2.lineCap='round';
      // Outer warning stripe
      ctx2.shadowBlur=4; ctx2.shadowColor='rgba(180,60,20,0.4)';
      ctx2.beginPath();
      ctx2.moveTo(road.pts[0][0]*sx, road.pts[0][1]*sy);
      for (let i=1;i<road.pts.length;i++) {
        ctx2.lineTo(road.pts[i][0]*sx, road.pts[i][1]*sy);
      }
      ctx2.stroke(); ctx2.shadowBlur=0;
      // Dashed center line
      ctx2.strokeStyle='rgba(200,100,40,0.5)'; ctx2.lineWidth=0.8;
      ctx2.setLineDash([4*sx,3*sx]);
      ctx2.beginPath();
      ctx2.moveTo(road.pts[0][0]*sx, road.pts[0][1]*sy);
      for (let i=1;i<road.pts.length;i++) ctx2.lineTo(road.pts[i][0]*sx, road.pts[i][1]*sy);
      ctx2.stroke();
      ctx2.restore();
    }

    // River routes — blue-green, dotted
    for (const route of INFRA_RIVER_ROUTES) {
      ctx2.save();
      ctx2.strokeStyle='#2a6a8a'; ctx2.lineWidth=1.8;
      ctx2.setLineDash([3*sx,4*sx]); ctx2.lineCap='round';
      ctx2.beginPath();
      ctx2.moveTo(route.pts[0][0]*sx, route.pts[0][1]*sy);
      for (let i=1;i<route.pts.length;i++) {
        const cpx=(route.pts[i-1][0]+route.pts[i][0])/2*sx;
        const cpy=(route.pts[i-1][1]+route.pts[i][1])/2*sy;
        ctx2.quadraticCurveTo(cpx,cpy,route.pts[i][0]*sx,route.pts[i][1]*sy);
      }
      ctx2.stroke(); ctx2.restore();
    }

    // Camps — green triangles
    for (const camp of INFRA_CAMPS) {
      const px=camp.x*sx, py=camp.y*sy, r=5*sx;
      ctx2.save();
      ctx2.fillStyle='#2a6a2a'; ctx2.strokeStyle='#4a9a4a'; ctx2.lineWidth=0.8;
      ctx2.beginPath();
      ctx2.moveTo(px,py-r); ctx2.lineTo(px+r,py+r*0.6); ctx2.lineTo(px-r,py+r*0.6);
      ctx2.closePath(); ctx2.fill(); ctx2.stroke();
      // Fire glow
      const gg=ctx2.createRadialGradient(px,py,0,px,py,r*2.5);
      gg.addColorStop(0,'rgba(200,120,30,0.25)'); gg.addColorStop(1,'rgba(200,120,30,0)');
      ctx2.fillStyle=gg; ctx2.beginPath(); ctx2.arc(px,py,r*2.5,0,Math.PI*2); ctx2.fill();
      ctx2.restore();
      hs(camp.x,camp.y,14,camp.label,'free camp',camp.desc);
    }

    // Checkpoints — red octagons
    for (const cp of INFRA_CHECKPOINTS) {
      const px=cp.x*sx, py=cp.y*sy, r=5*sx;
      ctx2.save();
      ctx2.fillStyle='#8a2020'; ctx2.strokeStyle='#c04040'; ctx2.lineWidth=0.8;
      ctx2.beginPath();
      for (let i=0;i<8;i++) {
        const a=(i/8)*Math.PI*2-Math.PI/8;
        i===0?ctx2.moveTo(px+Math.cos(a)*r,py+Math.sin(a)*r)
             :ctx2.lineTo(px+Math.cos(a)*r,py+Math.sin(a)*r);
      }
      ctx2.closePath(); ctx2.fill(); ctx2.stroke();
      ctx2.restore();
      hs(cp.x,cp.y,14,cp.label,'checkpoint / toll',cp.desc);
    }

    // Boundary zones — soft hatched areas
    for (const bz of BOUNDARY_ZONES) {
      const px=bz.x*sx, py=bz.y*sy;
      const col=bz.kind==='conflict'?'#8a4a20':bz.kind==='geological'?'#6a5a30':'#5a7a5a';
      ctx2.save();
      ctx2.strokeStyle=col; ctx2.lineWidth=0.6; ctx2.globalAlpha=0.5;
      // Hatch circle
      const hr=28*sx;
      for (let a=0;a<Math.PI*2;a+=0.4) {
        ctx2.beginPath();
        ctx2.moveTo(px+Math.cos(a)*hr*0.3,py+Math.sin(a)*hr*0.3);
        ctx2.lineTo(px+Math.cos(a)*hr,py+Math.sin(a)*hr);
        ctx2.stroke();
      }
      ctx2.globalAlpha=1;
      ctx2.fillStyle=col;
      ctx2.beginPath(); ctx2.arc(px,py,3*sx,0,Math.PI*2); ctx2.fill();
      ctx2.restore();
      hs(bz.x,bz.y,22,bz.label,bz.kind+' zone',bz.desc);
    }

    LAYERS.infra.cache=c;
  }

  function buildAllLayers() {
    const RW=Math.floor(MW/4), RH=Math.floor(MH/4);
    buildGeoLayer(RW,RH);
    buildSoilLayer(RW,RH);
    buildInfluenceLayer(RW,RH);
    buildInfraLayer(RW,RH);
  }

  function drawLayerComposite() {
    // Draw all offscreen layer caches in order, respecting alpha + on/off
    const layerOrder = ['geo','soil','biome','hydro','infra','influence'];
    for (const key of layerOrder) {
      const L=LAYERS[key];
      if (!L.on || !L.cache || L.alpha<0.01) continue;
      ctx.save();
      ctx.globalAlpha=L.alpha;
      ctx.drawImage(L.cache,0,0,MW,MH);
      ctx.restore();
    }
  }
  const GRID=8, GW=Math.ceil(MW/GRID), GH=Math.ceil(MH/GRID);
  let terrainGrid=null;
  function buildTerrain(){
    terrainGrid=new Uint8Array(GW*GH);
    for(let gy=0;gy<GH;gy++){
      for(let gx=0;gx<GW;gx++){
        const wx=gx*GRID+GRID/2, wy=gy*GRID+GRID/2;
        const nx=wx+(fbm(wx*0.003,wy*0.003,3,0)-0.5)*180;
        const ny=wy+(fbm(wx*0.003,wy*0.003,3,100)-0.5)*180;
        let best=0,bestD=Infinity;
        for(let i=0;i<SEEDS.length;i++){
          const d=(nx-SEEDS[i][0])**2+(ny-SEEDS[i][1])**2;
          if(d<bestD){bestD=d;best=i;}
        }
        terrainGrid[gy*GW+gx]=best;
      }
    }
  }

  function drawParchment(){
    // Base parchment — will be overlaid by terrain colour if heightmap ready
    const g=ctx.createRadialGradient(MW/2,MH/2,0,MW/2,MH/2,MW*0.8);
    g.addColorStop(0,'#ead8a8'); g.addColorStop(0.5,'#dfc490');
    g.addColorStop(0.85,'#d0ae70'); g.addColorStop(1,'#b89050');
    ctx.fillStyle=g; ctx.fillRect(0,0,MW,MH);
    // Grain (only when no heightmap cache)
    if(!terrainColorCache){
      ctx.save();
      for(let i=0;i<2500;i++){
        const x=Math.random()*MW, y=Math.random()*MH;
        const a=(fbm(x*0.01,y*0.01,2,7)-0.4)*0.09;
        if(a>0){ctx.fillStyle=`rgba(80,40,10,${a})`;ctx.fillRect(x,y,Math.random()*4+0.5,Math.random()*2+0.5);}
      }
      ctx.restore();
    }
    const vg=ctx.createRadialGradient(MW/2,MH/2,MW*0.25,MW/2,MH/2,MW*0.95);
    vg.addColorStop(0,'rgba(0,0,0,0)'); vg.addColorStop(1,'rgba(50,25,5,0.48)');
    ctx.fillStyle=vg; ctx.fillRect(0,0,MW,MH);
    ctx.strokeStyle='#8b6a3a'; ctx.lineWidth=3; ctx.strokeRect(20,20,MW-40,MH-40);
    ctx.strokeStyle='#a07040'; ctx.lineWidth=1; ctx.strokeRect(28,28,MW-56,MH-56);
  }

  function drawTerrain(){
    if(compositeCache){
      // Use the baked mix-map composite — the cartographer's argument
      ctx.drawImage(compositeCache, 0, 0, MW, MH);
      // Contour lines over the composite
      if(showContours && contourCache){
        ctx.save(); ctx.globalAlpha=0.5;
        ctx.drawImage(contourCache, 0, 0, MW, MH);
        ctx.restore();
      }
      return;
    }
    if(terrainColorCache){
      // Mix map loading — show hillshaded terrain + flat layer composite
      if(LAYERS.biome.on){
        ctx.save(); ctx.globalAlpha=LAYERS.biome.alpha;
        ctx.drawImage(terrainColorCache, 0, 0, MW, MH);
        ctx.restore();
      } else {
        ctx.save(); ctx.globalAlpha=0.4;
        ctx.drawImage(terrainColorCache, 0, 0, MW, MH);
        ctx.restore();
      }
      drawLayerComposite();
      if(showContours && contourCache){
        ctx.save(); ctx.globalAlpha=0.5;
        ctx.drawImage(contourCache, 0, 0, MW, MH);
        ctx.restore();
      }
      return;
    }
    // Fallback: Voronoi terrain
    if(!terrainGrid) buildTerrain();
    for(let gy=0;gy<GH;gy++){
      for(let gx=0;gx<GW;gx++){
        const idx=terrainGrid[gy*GW+gx];
        const s=SEEDS[idx];
        ctx.globalAlpha=s[5]; ctx.fillStyle=s[4];
        ctx.fillRect(gx*GRID,gy*GRID,GRID+1,GRID+1);
      }
    }
    ctx.globalAlpha=1;
  }

  function drawTree(x,y,s,col){
    ctx.fillStyle=col;
    ctx.beginPath();
    ctx.moveTo(x,y-s);
    ctx.lineTo(x+s*0.55,y+s*0.3); ctx.lineTo(x+s*0.18,y+s*0.3);
    ctx.lineTo(x+s*0.18,y+s);    ctx.lineTo(x-s*0.18,y+s);
    ctx.lineTo(x-s*0.18,y+s*0.3);ctx.lineTo(x-s*0.55,y+s*0.3);
    ctx.closePath(); ctx.fill();
  }

  function drawForestTexture(){
    if(!terrainGrid) return;
    ctx.save(); ctx.globalAlpha=0.5;
    for(let y=0;y<MH;y+=28){
      for(let x=0;x<MW;x+=28){
        const gx=Math.floor(x/GRID),gy=Math.floor(y/GRID);
        if(gx>=0&&gx<GW&&gy>=0&&gy<GH){
          const idx=terrainGrid[gy*GW+gx];
          if(SEEDS[idx][3]==='forest'){
            const jx=x+(fbm(x*0.02,y*0.02,2,5)-0.5)*13;
            const jy=y+(fbm(x*0.02,y*0.02,2,15)-0.5)*13;
            drawTree(jx,jy,5+fbm(jx*0.03,jy*0.03,2,25)*5,SEEDS[idx][4]);
          }
        }
      }
    }
    ctx.restore();
  }

  function drawOcean(){
    const coast=WATERS.find(w=>w.isCoast);
    if(!coast) return;
    ctx.save();
    ctx.beginPath();
    ctx.moveTo(0,MH); ctx.lineTo(coast.pts[0][0],coast.pts[0][1]);
    for(let i=1;i<coast.pts.length;i++){
      const cp1x=(coast.pts[i-1][0]+coast.pts[i][0])/2-15;
      const cp2x=(coast.pts[i-1][0]+coast.pts[i][0])/2+15;
      ctx.bezierCurveTo(cp1x,coast.pts[i-1][1]+25,cp2x,coast.pts[i][1]-25,coast.pts[i][0],coast.pts[i][1]);
    }
    ctx.lineTo(MW,MH); ctx.closePath();
    const og=ctx.createLinearGradient(0,1780,0,MH);
    og.addColorStop(0,'rgba(40,60,90,0.7)'); og.addColorStop(1,'rgba(20,30,60,0.85)');
    ctx.fillStyle=og; ctx.fill();
    ctx.globalAlpha=0.13;
    for(let wy=1840;wy<MH;wy+=18){
      for(let wx=50;wx<MW-50;wx+=55){
        ctx.beginPath(); ctx.moveTo(wx,wy);
        ctx.bezierCurveTo(wx+14,wy-5,wx+28,wy+5,wx+42,wy);
        ctx.strokeStyle='#a0c0e0'; ctx.lineWidth=0.8; ctx.stroke();
      }
    }
    ctx.globalAlpha=1;
    ctx.beginPath(); ctx.moveTo(coast.pts[0][0],coast.pts[0][1]);
    for(let i=1;i<coast.pts.length;i++){
      const cp1x=(coast.pts[i-1][0]+coast.pts[i][0])/2-10;
      const cp2x=(coast.pts[i-1][0]+coast.pts[i][0])/2+10;
      ctx.bezierCurveTo(cp1x,coast.pts[i-1][1]+20,cp2x,coast.pts[i][1]-20,coast.pts[i][0],coast.pts[i][1]);
    }
    ctx.strokeStyle='#5a8aaa'; ctx.lineWidth=2.5; ctx.setLineDash([10,5]); ctx.stroke();
    ctx.setLineDash([]);
    ctx.restore();
  }

  function drawWaters(){
    for(const w of WATERS){
      if(w.isCoast) continue;
      ctx.save(); ctx.strokeStyle=w.color; ctx.lineWidth=w.w;
      ctx.globalAlpha=0.72; ctx.lineCap='round';
      if(w.dash) ctx.setLineDash(w.dash);
      ctx.beginPath(); ctx.moveTo(w.pts[0][0],w.pts[0][1]);
      for(let i=1;i<w.pts.length;i++){
        const cpx=(w.pts[i-1][0]+w.pts[i][0])/2+(fbm(w.pts[i][0]*0.004,w.pts[i][1]*0.004,2,i*13)-0.5)*20;
        const cpy=(w.pts[i-1][1]+w.pts[i][1])/2+(fbm(w.pts[i][0]*0.004,w.pts[i][1]*0.004,2,i*17)-0.5)*20;
        ctx.quadraticCurveTo(cpx,cpy,w.pts[i][0],w.pts[i][1]);
      }
      ctx.stroke(); ctx.restore();
      if(w.label){ const m=w.pts[Math.floor(w.pts.length/2)]; hs(m[0],m[1],14,w.label,'waterway',w.desc); }
    }
  }

  function drawRoads(){
    for(const r of ROADS){
      ctx.save(); ctx.strokeStyle=r.color; ctx.lineWidth=r.w;
      ctx.setLineDash(r.dash||[]); ctx.lineCap='round';
      ctx.beginPath(); ctx.moveTo(r.pts[0][0],r.pts[0][1]);
      for(let i=1;i<r.pts.length;i++){
        const cpx=(r.pts[i-1][0]+r.pts[i][0])/2+(fbm(r.pts[i][0]*0.005,r.pts[i][1]*0.005,2,r.w*10)-0.5)*8;
        const cpy=(r.pts[i-1][1]+r.pts[i][1])/2+(fbm(r.pts[i][0]*0.005,r.pts[i][1]*0.005,2,r.w*20)-0.5)*8;
        ctx.quadraticCurveTo(cpx,cpy,r.pts[i][0],r.pts[i][1]);
      }
      ctx.stroke(); ctx.restore();
      const m=r.pts[Math.floor(r.pts.length/2)];
      hs(m[0],m[1],16,r.label,(r.dash[0]>5)?'imperial road':'old trail',r.desc);
    }
  }

  function drawMountains(){
    for(const m of MOUNTAINS){
      ctx.save();
      ctx.shadowBlur=12; ctx.shadowColor='rgba(0,0,0,0.3)';
      ctx.shadowOffsetX=4; ctx.shadowOffsetY=6;
      ctx.fillStyle='#9a8860'; ctx.strokeStyle='#6a5830'; ctx.lineWidth=1.5;
      ctx.beginPath();
      ctx.moveTo(m.x,m.y-m.r); ctx.lineTo(m.x+m.r*0.85,m.y+m.r*0.55); ctx.lineTo(m.x-m.r*0.85,m.y+m.r*0.55);
      ctx.closePath(); ctx.fill(); ctx.stroke(); ctx.shadowBlur=0;
      ctx.fillStyle='#eeddc0';
      ctx.beginPath(); ctx.moveTo(m.x,m.y-m.r); ctx.lineTo(m.x+m.r*0.22,m.y-m.r*0.38); ctx.lineTo(m.x-m.r*0.22,m.y-m.r*0.38); ctx.closePath(); ctx.fill();
      ctx.fillStyle='#8a7850';
      ctx.beginPath(); ctx.moveTo(m.x-m.r*0.28,m.y-m.r*0.42); ctx.lineTo(m.x+m.r*0.32,m.y+m.r*0.55); ctx.lineTo(m.x-m.r*0.9,m.y+m.r*0.55); ctx.closePath(); ctx.fill(); ctx.stroke();
      ctx.font=`italic ${Math.max(10,m.r*0.22)}px Georgia`;
      ctx.fillStyle='rgba(230,210,160,0.85)'; ctx.textAlign='center';
      ctx.fillText(m.label,m.x+1,m.y+m.r+14);
      ctx.fillStyle='#2a1a08'; ctx.fillText(m.label,m.x,m.y+m.r+13);
      ctx.restore();
      hs(m.x,m.y,m.r,m.label,'mountain range',m.desc);
    }
  }

  function drawSettlement(x,y,r,label,type,desc){
    ctx.save();
    ctx.shadowBlur=8; ctx.shadowColor='rgba(0,0,0,0.4)';
    const isCommons=type==='commons', isPort=type==='port';
    const col=isPort?'#1a5a5a':isCommons?'#2a5a2a':'#6a2020';
    const fill=isPort?'#2a8a8a':isCommons?'#4a8a4a':'#c04030';
    if(isPort){
      for(let i=0;i<8;i++){
        const a=(i/8)*Math.PI*2-Math.PI/2;
        ctx.beginPath(); ctx.moveTo(x,y); ctx.lineTo(x+Math.cos(a)*r*1.8,y+Math.sin(a)*r*1.8);
        ctx.strokeStyle=col; ctx.lineWidth=1.2; ctx.stroke();
      }
      ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2);
      ctx.fillStyle=fill; ctx.fill(); ctx.strokeStyle=col; ctx.lineWidth=2; ctx.stroke();
      ctx.fillStyle='#e8d8b0'; ctx.font=`${r}px serif`; ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText('⚓',x,y+1);
    } else {
      ctx.beginPath();
      for(let i=0;i<6;i++){
        const a=(i/6)*Math.PI*2-Math.PI/6;
        const px=x+Math.cos(a)*r, py=y+Math.sin(a)*r;
        i===0?ctx.moveTo(px,py):ctx.lineTo(px,py);
      }
      ctx.closePath(); ctx.fillStyle=fill; ctx.globalAlpha=0.9; ctx.fill();
      ctx.strokeStyle=col; ctx.lineWidth=2; ctx.globalAlpha=1; ctx.stroke();
      ctx.beginPath(); ctx.arc(x,y,r*0.28,0,Math.PI*2); ctx.fillStyle='#e8d8b0'; ctx.fill();
    }
    ctx.shadowBlur=0;
    ctx.font=`italic bold ${Math.max(9.5,r*0.72)}px Georgia`;
    const tw=ctx.measureText(label).width;
    ctx.fillStyle='rgba(220,200,150,0.75)'; ctx.fillRect(x-tw/2-3,y+r+2,tw+6,15);
    ctx.fillStyle='#1a0a04'; ctx.textAlign='center'; ctx.textBaseline='top';
    ctx.fillText(label,x,y+r+3);
    ctx.restore();
    hs(x,y,r,label,isPort?'port city':isCommons?'commons settlement':'encloser settlement',desc);
  }

  function drawRuin(x,y,label,warm,desc){
    ctx.save();
    const col=warm?'#8a6a30':'#5a5040', sz=13;
    ctx.strokeStyle=col; ctx.lineWidth=1.5; ctx.setLineDash([3,3]);
    ctx.beginPath(); ctx.moveTo(x-sz,y-sz); ctx.lineTo(x+sz,y-sz); ctx.lineTo(x+sz,y); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x+sz,y+sz); ctx.lineTo(x-sz,y+sz); ctx.lineTo(x-sz,y-sz); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle=warm?'#9a7a38':'#5a5048';
    ctx.beginPath(); ctx.moveTo(x,y-sz-9); ctx.lineTo(x+7,y-sz-1); ctx.lineTo(x-7,y-sz-1); ctx.closePath(); ctx.fill();
    if(warm){
      const gg=ctx.createRadialGradient(x,y,0,x,y,sz*0.7);
      gg.addColorStop(0,'rgba(200,120,40,0.2)'); gg.addColorStop(1,'rgba(200,120,40,0)');
      ctx.beginPath(); ctx.arc(x,y,sz*0.7,0,Math.PI*2); ctx.fillStyle=gg; ctx.fill();
    }
    ctx.font='italic 9px Georgia'; ctx.fillStyle=col; ctx.textAlign='center';
    ctx.fillText(label,x,y+sz+11);
    ctx.restore();
    hs(x,y,sz+6,label,warm?'warm ruin':'cold ruin',desc);
  }

  function drawUnderground(x,y,label,desc){
    ctx.save(); const r=14;
    for(let i=3;i>0;i--){
      ctx.beginPath(); ctx.arc(x,y,r*i*0.42,0,Math.PI*2);
      ctx.strokeStyle=`rgba(20,70,20,${0.22+i*0.13})`; ctx.lineWidth=1; ctx.stroke();
    }
    ctx.beginPath(); ctx.arc(x,y,r*0.38,0,Math.PI*2);
    ctx.fillStyle='#0f2a0f'; ctx.fill(); ctx.strokeStyle='#2a6a2a'; ctx.lineWidth=1.5; ctx.stroke();
    ctx.font='italic 9px Georgia'; ctx.fillStyle='#1a4a1a';
    ctx.textAlign='center'; ctx.fillText(label,x,y+r*1.5+5);
    ctx.restore();
    hs(x,y,r,label,'underground entrance',desc);
  }

  function drawWizard(x,y,label,desc){
    ctx.save(); const r=11;
    ctx.strokeStyle='rgba(200,160,60,0.45)'; ctx.lineWidth=0.8;
    for(let i=0;i<8;i++){
      const a=(i/8)*Math.PI*2;
      ctx.beginPath(); ctx.moveTo(x,y); ctx.lineTo(x+Math.cos(a)*r*1.9,y+Math.sin(a)*r*1.9); ctx.stroke();
    }
    ctx.beginPath(); ctx.arc(x,y,r*0.7,0,Math.PI*2);
    ctx.fillStyle='rgba(200,160,60,0.22)'; ctx.fill();
    ctx.fillStyle='#c8a040'; ctx.font='bold 14px serif';
    ctx.textAlign='center'; ctx.textBaseline='middle'; ctx.fillText('✦',x,y);
    ctx.font='italic 9px Georgia'; ctx.fillStyle='#8a6820';
    ctx.textBaseline='top'; ctx.fillText(label,x,y+r+4);
    ctx.restore();
    hs(x,y,r,label,'wizard figure',desc);
  }

  function drawLabels(){
    const items=[
      {x:1400,y:1920,text:'THE UNCHARTED OCEAN OF CONSCIOUSNESS',size:18,color:'#3a5a7a',italic:true},
      {x:1400,y:1958,text:'Here the map ends. The territory continues.',size:10,color:'#2a4a6a',italic:true},
      {x:300,y:80,text:'THE KNOWN LANDS',size:14,color:'#7a5a2a',italic:true},
      {x:1400,y:48,text:'A Map of Consciousness — Compiled from field notes, ruins, and conversations with Others',size:9,color:'#7a5a2a',italic:true},
      {x:2700,y:1700,text:'THE FRONTIER',size:13,color:'#2a3a2a',italic:true,rotate:-5},
      {x:2700,y:1730,text:'(always extending)',size:9,color:'#2a3a2a',italic:true,rotate:-5},
    ];
    const inscriptions=[
      {x:1100,y:600,text:'The commons was not enclosed because it failed.',size:9.5,color:'rgba(80,60,20,0.5)',italic:true,rotate:2},
      {x:1080,y:618,text:'It was enclosed because it worked.',size:9.5,color:'rgba(80,60,20,0.5)',italic:true,rotate:2},
      {x:400,y:1880,text:'"The enclosure cannot finally take the living world."',size:10,color:'rgba(50,80,60,0.58)',italic:true},
      {x:1400,y:1840,text:'Life is what we have in common.',size:11,color:'rgba(50,70,90,0.62)',italic:true},
    ];
    for(const l of [...items,...inscriptions]){
      ctx.save(); ctx.translate(l.x,l.y);
      if(l.rotate) ctx.rotate(l.rotate*Math.PI/180);
      ctx.font=`${l.italic?'italic ':''}${l.size}px Georgia`;
      ctx.fillStyle=l.color; ctx.textAlign='center'; ctx.globalAlpha=0.78;
      ctx.fillText(l.text,0,0); ctx.restore();
    }
    // Territory name labels
    for(const s of SEEDS){
      const gx=Math.floor(s[0]/GRID), gy=Math.floor(s[1]/GRID);
      if(gx>=0&&gx<GW&&gy>=0&&gy<GH){
        ctx.save(); ctx.font='italic bold 11px Georgia';
        ctx.fillStyle='rgba(230,215,165,0.7)'; ctx.textAlign='center'; ctx.globalAlpha=0.65;
        ctx.fillText(s[2],s[0],s[1]);
        ctx.restore();
      }
    }
  }

  function drawCompassRose(){
    const cx=MW-130,cy=130,r=55;
    ctx.save();
    for(const [d,deg,col] of [['N',0,'#8b3a1a'],['E',90,'#7a5a2a'],['S',180,'#7a5a2a'],['W',270,'#7a5a2a']]){
      const a=deg*Math.PI/180-Math.PI/2;
      ctx.strokeStyle=col; ctx.fillStyle=col; ctx.lineWidth=1.2;
      ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(cx+Math.cos(a)*r,cy+Math.sin(a)*r); ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(cx+Math.cos(a)*r,cy+Math.sin(a)*r);
      ctx.lineTo(cx+Math.cos(a-0.28)*(r*0.65),cy+Math.sin(a-0.28)*(r*0.65));
      ctx.lineTo(cx+Math.cos(a+0.28)*(r*0.65),cy+Math.sin(a+0.28)*(r*0.65));
      ctx.closePath(); ctx.fill();
      ctx.font=`bold ${r*0.38}px Georgia`; ctx.fillStyle='#5a3a1a';
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText(d,cx+Math.cos(a)*(r+r*0.38),cy+Math.sin(a)*(r+r*0.38));
    }
    ctx.beginPath(); ctx.arc(cx,cy,r*0.14,0,Math.PI*2); ctx.fillStyle='#8b6a3a'; ctx.fill();
    const sx=MW-240,sy=MH-55;
    ctx.strokeStyle='#6a4a20'; ctx.lineWidth=2;
    ctx.beginPath(); ctx.moveTo(sx,sy); ctx.lineTo(sx+140,sy);
    ctx.moveTo(sx,sy-5); ctx.lineTo(sx,sy+5);
    ctx.moveTo(sx+70,sy-3); ctx.lineTo(sx+70,sy+3);
    ctx.moveTo(sx+140,sy-5); ctx.lineTo(sx+140,sy+5); ctx.stroke();
    ctx.fillStyle='#4a3010'; ctx.fillRect(sx,sy-2,70,4);
    ctx.font='9px Georgia'; ctx.fillStyle='#4a3010'; ctx.textAlign='center';
    ctx.fillText('One generation of struggle',sx+70,sy+16);
    ctx.restore();
  }

  function draw(){
    ctx.clearRect(0,0,W,H);
    ctx.save(); ctx.translate(tx,ty); ctx.scale(scale,scale);
    drawParchment(); drawTerrain(); drawForestTexture(); drawOcean();
    drawWaters(); drawRoads(); drawMountains();
    for(const [x,y,l,d] of WARM_R) drawRuin(x,y,l,true,d);
    for(const [x,y,l,d] of COLD_R) drawRuin(x,y,l,false,d);
    for(const [x,y,r,l,d] of UNDERGROUND) drawUnderground(x,y,l,d);
    for(const [x,y,r,l,d] of COMMONS_S) drawSettlement(x,y,r,l,'commons',d);
    for(const [x,y,r,l,d] of ENCLOSER_S) drawSettlement(x,y,r,l,'encloser',d);
    drawSettlement(PORT.x,PORT.y,PORT.r,PORT.label,'port',PORT.desc);
    for(const [x,y,r,l,d] of WIZARDS) drawWizard(x,y,l,d);
    drawFlowParticles();
    drawLabels(); drawCompassRose();
    ctx.restore();
  }

  // ── Hit test ────────────────────────────────────────────────────
  function hitTest(mx,my){
    const wx=(mx-tx)/scale, wy=(my-ty)/scale;
    for(const h of HOTSPOTS){
      if(Math.hypot(wx-h.x,wy-h.y)<h.r+12){ showTip(mx,my,h); return; }
    }
    hideTip();
  }
  function showTip(mx,my,h){
    tipEl.style.display='block';
    tipEl.innerHTML=`<strong>${h.label}</strong><em>${h.kind}</em>${h.desc}`;
    let lx=mx+16,ly=my+16;
    if(lx+240>window.innerWidth) lx=mx-250;
    if(ly+140>window.innerHeight) ly=my-150;
    tipEl.style.left=lx+'px'; tipEl.style.top=ly+'px';
  }
  function hideTip(){ tipEl.style.display='none'; }

  // ── Input ──────────────────────────────────────────────────────
  let drag=false,lx,ly,pinchD=null;
  cvs.addEventListener('mousedown',e=>{drag=true;lx=e.clientX;ly=e.clientY;});
  cvs.addEventListener('mousemove',e=>{
    if(drag){tx+=e.clientX-lx;ty+=e.clientY-ly;lx=e.clientX;ly=e.clientY;clamp();draw();}
    else hitTest(e.clientX,e.clientY);
  });
  cvs.addEventListener('mouseup',()=>drag=false);
  cvs.addEventListener('mouseleave',()=>{drag=false;hideTip();});
  cvs.addEventListener('wheel',e=>{e.preventDefault();zoomAt(e.clientX,e.clientY,e.deltaY<0?1.12:0.89);},{passive:false});
  cvs.addEventListener('touchstart',e=>{
    if(e.touches.length===1){drag=true;lx=e.touches[0].clientX;ly=e.touches[0].clientY;}
    else if(e.touches.length===2) pinchD=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
  },{passive:true});
  cvs.addEventListener('touchmove',e=>{
    e.preventDefault();
    if(e.touches.length===1&&drag){
      tx+=e.touches[0].clientX-lx;ty+=e.touches[0].clientY-ly;
      lx=e.touches[0].clientX;ly=e.touches[0].clientY;clamp();draw();
    } else if(e.touches.length===2&&pinchD){
      const nd=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
      const cx=(e.touches[0].clientX+e.touches[1].clientX)/2;
      const cy=(e.touches[0].clientY+e.touches[1].clientY)/2;
      zoomAt(cx,cy,nd/pinchD); pinchD=nd;
    }
  },{passive:false});
  cvs.addEventListener('touchend',()=>{drag=false;pinchD=null;});
  cvs.addEventListener('click',e=>{
    const wx=(e.clientX-tx)/scale,wy=(e.clientY-ty)/scale;
    for(const h of HOTSPOTS){
      if(Math.hypot(wx-h.x,wy-h.y)<h.r+14){
        tipEl.style.display==='block'?hideTip():showTip(e.clientX,e.clientY,h); return;
      }
    }
    hideTip();
  });

  function zoomAt(cx,cy,f){
    const ns=Math.min(Math.max(scale*f,0.2),5);
    tx=cx-(cx-tx)*(ns/scale); ty=cy-(cy-ty)*(ns/scale);
    scale=ns; clamp(); draw();
  }
  function clamp(){
    const pad=120;
    tx=Math.min(pad,Math.max(W-MW*scale-pad,tx));
    ty=Math.min(pad,Math.max(H-MH*scale-pad,ty));
  }

  // ── Layer panel wiring ────────────────────────────────────────────
  document.querySelectorAll('.ltrack-slider').forEach(el => {
    const key=el.dataset.layer;
    el.addEventListener('input', () => {
      LAYERS[key].alpha=el.value/100;
      // Rebuild composite when panel changes — the DJ adjusts the mix
      if(mmReady && hmReady){
        buildCompositeCache();
      }
      if(!showFlow) draw();
    });
  });
  document.querySelectorAll('.ltrack-eye').forEach(el => {
    const key=el.dataset.layer;
    el.classList.add('on');
    el.addEventListener('click', () => {
      LAYERS[key].on=!LAYERS[key].on;
      el.classList.toggle('on', LAYERS[key].on);
      const track=document.getElementById('lt-'+key);
      if(track) track.classList.toggle('muted',!LAYERS[key].on);
      if(mmReady && hmReady) buildCompositeCache();
      if(!showFlow) draw();
    });
  });

  document.getElementById('zinBtn').onclick=()=>zoomAt(W/2,H/2,1.3);
  document.getElementById('zoutBtn').onclick=()=>zoomAt(W/2,H/2,0.77);
  document.getElementById('homeBtn').onclick=()=>{
    scale=Math.min(W/MW,H/MH)*0.92;
    tx=(W-MW*scale)/2; ty=(H-MH*scale)/2; draw();
  };
  document.getElementById('flowBtn').onclick=function(){
    showFlow=!showFlow;
    this.style.color=showFlow?'#60b0d0':'#c8a96e';
    this.style.borderColor=showFlow?'#60b0d0':'#8b6a3a';
    if(showFlow && !flowAnim) animateFlow();
    else if(!showFlow) draw();
  };
  document.getElementById('contourBtn').onclick=function(){
    showContours=!showContours;
    this.style.color=showContours?'#a0c060':'#c8a96e';
    this.style.borderColor=showContours?'#a0c060':'#8b6a3a';
    draw();
  };

  window.addEventListener('resize',()=>{resize();draw();});
  resize();
  scale=Math.min(W/MW,H/MH)*0.9;
  tx=(W-MW*scale)/2; ty=(H-MH*scale)/2;
  // Draw immediately with fallback, then upgrade when heightmap loads
  buildTerrain();
  draw();
  loadHeightmap().then(()=>loadMixmap());
})();
</script>
</body>
</html>
