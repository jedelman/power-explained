---
import Base from '../../layouts/Base.astro'
import fs from 'node:fs'
import { resolve } from 'path'
import yaml from 'js-yaml'
import { loadCorpus } from '../../lib/load-corpus.mjs'
import { loadThreads, sharedGestureThreads, threadCrossings, threadNetwork } from '../../lib/threads.mjs'
import { terrain, makeRouter } from '../../lib/topo.mjs'

// The atlas — the map of the rhizome. Spine step 3 of the composable river
// (see for-agents/composition-pass-instructions.md). Two views, both computed
// from existing manifests at build time, no new prose:
//   1. The trail map — a node-link network of the threads and where they cross
//      (layout baked at build time in threads.mjs; a small vanilla-JS handler
//      lights a station's crossings on hover — the one place this page uses JS).
//   2. The field — every gesture in the river, chapter by chapter, with thread
//      membership overlaid and the true rhizome nodes (a gesture on more than
//      one thread) marked.

const RIVER = resolve('src/content/manifests/the-river.manifest.yml')
const river = yaml.load(fs.readFileSync(RIVER, 'utf8'))
const corpus = loadCorpus(resolve('.'))

const threads = loadThreads()
const shared = sharedGestureThreads()
const crossings = threadCrossings()

// The trail map — node-link layout baked at build time (see threads.mjs).
// Two orientations: landscape for wide screens, a transposed portrait (river
// running top-to-bottom, bands as columns) that swaps in on mobile.
const anchorMin = 45 // big threads keep their label always-on for orientation

const views = ['landscape', 'portrait'].map(key => {
  const net = threadNetwork(key === 'portrait' ? { orientation: 'portrait' } : {})
  // Eroded watershed from the layout's density (see topo.mjs): contours of the
  // carved surface + the drainage network, plus a router that walks each trail
  // the least-energy way over that terrain.
  const { contours, streams, field } = terrain(net.nodes, net.width, net.height, {
    cols: net.vertical ? 64 : 150,
  })
  const route = makeRouter(field)
  const edges = net.edges
    .filter(e => e.type === 'gesture')
    .map(e => {
      const a = net.bySlug[e.a]
      const b = net.bySlug[e.b]
      return { ...e, d: route(a.x, a.y, b.x, b.y), aLabel: a.label, bLabel: b.label }
    })
  return { key, net, contours, streams, edges }
})
const meta = views[0].net // shared counts for the caption

// gestureId -> [thread] for every thread member (not just shared nodes)
const onThreads = {}
for (const t of threads) {
  for (const id of t.gestures) (onThreads[id] ||= []).push(t)
}

const bySlug = Object.fromEntries(corpus.plateaus.map(p => [p.slug, p]))
const rows = (river.sources || [])
  .map(slug => {
    const ch = bySlug[slug]
    if (!ch) return null
    return {
      slug,
      title: ch.title || slug,
      cells: ch.gestures.map(id => {
        const g = corpus.gestures[id]
        const on = onThreads[id] || []
        return {
          id,
          title: g?.title || id,
          threads: on.map(t => t.h1 || t.title),
          n: on.length,
        }
      }),
    }
  })
  .filter(Boolean)

const gestureCount = rows.reduce((n, r) => n + r.cells.length, 0)
const memberCount = rows.reduce((n, r) => n + r.cells.filter(c => c.n > 0).length, 0)
const nodeCount = Object.keys(shared).length
const edgeCount =
  Object.values(crossings).reduce((n, list) => n + list.length, 0) / 2
---
<Base
  title="Atlas — Power Explained"
  description="The map of the rhizome: every gesture in the river, with the threads that cross it."
>
  <div class="article-wrap atlas-wrap">
    <p class="book-nav">
      <a href="/book">← The Book</a>
      <span class="book-nav-sep">·</span>
      <a href="/book/path">Threads</a>
      <span class="book-nav-sep">·</span>
      <span>Experimental · the composable river</span>
    </p>

    <header class="atlas-head">
      <p class="atlas-label">Atlas</p>
      <h1>The map of the rhizome</h1>
      <p class="atlas-dek">
        Every gesture in the river, chapter by chapter, in canonical order.
        An outlined cell sits on a thread; a filled cell is a node — a gesture
        where threads cross. The line is one walk through this field.
        <a href="/book/path">The threads are the others.</a>
      </p>
      <p class="atlas-counts">
        {gestureCount} gestures · {rows.length} chapters · {threads.length} threads
        · {memberCount} on a thread · {nodeCount} nodes · {edgeCount} crossings
      </p>
    </header>

    <section class="trailmap">
      <div class="tm-head">
        <h2>The trail map</h2>
        <p class="tm-dek">
          Every thread is a station, placed by the commons it shares — threads
          that pass through the same gestures pull together and settle into
          clusters, the basecamps and temples of the range. The land is a
          watershed eroded from that terrain; each trail takes the low way
          across it. Hover (or tap) a station to light its crossings.
        </p>
        <ul class="tm-key">
          <li><span class="swatch trail"></span> a trail (thread)</li>
          <li><span class="swatch cross"></span> a crossing</li>
          <li><span class="swatch stream"></span> drainage</li>
          <li><span class="swatch contour"></span> contour</li>
          <li class="tm-key-sep">stations settle by what they share</li>
        </ul>
      </div>

      {views.map(v => (
        <div class={`tm-scroll tm-view ${v.key}`}>
          <svg
            class="tm-svg"
            viewBox={`0 0 ${v.net.width} ${Math.round(v.net.height)}`}
            role="img"
            aria-label="Network map of the book's threads and where they cross."
          >
            <g class="tm-contours" aria-hidden="true">
              {v.contours.map(c => (
                <path class={`tm-contour${c.index ? ' index' : ''}`} d={c.d} />
              ))}
            </g>

            <g class="tm-streams" aria-hidden="true">
              {v.streams.map(s => (
                <path class="tm-stream" d={s.d} stroke-width={s.w} />
              ))}
            </g>

            <g class="tm-edges">
              {v.edges.map(e => (
                <path
                  class={`tm-edge${e.weight >= 2 ? ' bb' : ''}`}
                  data-a={e.a}
                  data-b={e.b}
                  d={e.d}
                  stroke-width={Math.min(0.5 + e.weight * 0.3, 2.4)}
                >
                  <title>{`${e.aLabel} ✕ ${e.bLabel} — ${e.via}`}</title>
                </path>
              ))}
            </g>

            <g class="tm-nodes">
              {v.net.nodes.map(n => (
                <a
                  class={`tm-node ax-${n.axis}${n.count >= anchorMin ? ' anchor' : ''}`}
                  data-slug={n.slug}
                  href={`/book/path/${n.slug}`}
                  transform={`translate(${n.x} ${n.y})`}
                >
                  <title>{`${n.label} · ${n.count} gestures · crosses ${n.degree} threads`}</title>
                  <circle r={n.r} />
                  <text class="tm-label" x={n.r + 3} y="3.2">{n.label}</text>
                </a>
              ))}
            </g>
          </svg>
        </div>
      ))}

      <p class="tm-foot">
        {meta.nodes.length} threads · {views[0].edges.length} crossings (where two
        threads share a gesture); thicker trails meet at more than one. The land
        is a watershed eroded from the network's own density — high ground where
        the threads gather, blue where the flow collects. <a href="/book/path">Walk the threads →</a>
      </p>
    </section>

    <ul class="atlas-legend">
      {threads
        .slice()
        .sort((a, b) => (a.h1 || a.title).localeCompare(b.h1 || b.title))
        .map(t => (
          <li>
            <a href={`/book/path/${t.slug}`}>{t.h1 || t.title}</a>
            <span class="legend-count">{t.gestures.length}</span>
          </li>
        ))}
    </ul>

    <div class="atlas-field">
      {rows.map(r => (
        <div class="atlas-row">
          <a class="atlas-chapter" href={`/book/${r.slug}`}>{r.title}</a>
          <div class="atlas-cells">
            {r.cells.map(c => (
              <span
                class={`cell${c.n > 1 ? ' node' : c.n === 1 ? ' member' : ''}`}
                title={`${c.id} · ${c.title}${c.threads.length ? ` · ${c.threads.join(' / ')}` : ''}`}
              />
            ))}
          </div>
        </div>
      ))}
    </div>

    <p class="atlas-foot">
      A thread is an ordering of gestures the book already holds. The atlas is
      the field they are drawn from. <a href="/book/river">Read the whole river →</a>
    </p>
  </div>
</Base>

<style>
  .atlas-wrap { max-width: 52rem; }
  .book-nav {
    font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.1em;
    text-transform: uppercase; opacity: 0.4; margin-bottom: 2rem;
    display: flex; gap: 0.5rem; align-items: center;
  }
  .book-nav a { color: inherit; text-decoration: none; }
  .book-nav a:hover { color: var(--red); }
  .book-nav-sep { opacity: 0.4; }

  .atlas-head { margin: 0 0 2rem; }
  .atlas-label {
    font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em;
    text-transform: uppercase; opacity: 0.45; margin-bottom: 0.75rem;
  }
  .atlas-dek {
    font-size: 0.95rem; line-height: 1.7; opacity: 0.75; max-width: 36rem;
    margin-top: 1rem;
  }
  .atlas-dek a { color: var(--red); text-decoration: none; }
  .atlas-dek a:hover { text-decoration: underline; }
  .atlas-counts {
    font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.06em;
    opacity: 0.5; margin-top: 1rem;
  }

  .atlas-legend {
    list-style: none; padding: 0.75rem 0; margin: 0 0 2rem;
    display: flex; flex-wrap: wrap; gap: 0.4rem 1.25rem;
    border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);
  }
  .atlas-legend a {
    color: var(--ink); text-decoration: none; font-size: 0.85rem;
  }
  .atlas-legend a:hover { color: var(--red); }
  .legend-count {
    font-family: var(--mono); font-size: 0.6rem; opacity: 0.45;
    margin-left: 0.3rem;
  }

  .atlas-field { display: grid; gap: 0.9rem; }
  .atlas-row {
    display: grid; grid-template-columns: 11rem 1fr; gap: 1rem;
    align-items: start;
  }
  .atlas-chapter {
    font-family: var(--mono); font-size: 0.65rem; line-height: 1.5;
    letter-spacing: 0.03em; color: var(--ink); opacity: 0.65;
    text-decoration: none; padding-top: 0.05rem;
  }
  .atlas-chapter:hover { color: var(--red); opacity: 1; }
  .atlas-cells { display: flex; flex-wrap: wrap; gap: 3px; }
  .cell {
    width: 9px; height: 9px; border-radius: 1px;
    background: rgba(var(--ink-rgb), 0.13);
  }
  .cell.member {
    background: var(--paper-mid);
    box-shadow: inset 0 0 0 1.5px var(--red);
  }
  .cell.node { background: var(--red); }

  .atlas-foot {
    margin: 3rem 0 2rem; font-family: var(--mono); font-size: 0.7rem;
    opacity: 0.5; line-height: 1.7;
  }
  .atlas-foot a { color: var(--red); text-decoration: none; }
  .atlas-foot a:hover { text-decoration: underline; }

  /* --- the trail map --- */
  .trailmap { margin: 0 0 3rem; }
  .tm-head h2 {
    font-family: var(--display); font-size: 1.4rem; font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .tm-dek {
    font-size: 0.9rem; line-height: 1.65; opacity: 0.72; max-width: 38rem;
    margin: 0 0 0.85rem;
  }
  /* Green Trails topo palette — scoped to the map */
  .trailmap {
    --trail: #4f7a3f;      /* trail green */
    --trail-deep: #3c5f30;
    --contour: #9a7b54;    /* topo contour brown */
    --water: #6f93b0;      /* drainage blue */
  }
  .tm-key {
    list-style: none; padding: 0; margin: 0 0 1rem; display: flex;
    flex-wrap: wrap; gap: 0.25rem 1.1rem; align-items: center;
    font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.04em;
    text-transform: uppercase; opacity: 0.6;
  }
  .tm-key li { display: flex; align-items: center; gap: 0.4rem; }
  .tm-key .swatch { width: 16px; height: 0; display: inline-block; }
  .tm-key .swatch.trail { border-top: 2px solid var(--trail); }
  .tm-key .swatch.cross {
    width: 7px; height: 7px; border-radius: 50%; background: var(--ink);
  }
  .tm-key .swatch.stream { border-top: 2px solid var(--water); }
  .tm-key .swatch.contour { border-top: 1px solid var(--contour); }
  .tm-key-sep { opacity: 0.5; }

  .tm-scroll {
    overflow-x: auto; border: 1px solid var(--rule); border-radius: 3px;
    background: #f7f1e3; /* aged-paper map base */
  }
  .tm-svg { display: block; width: 100%; height: auto; }
  /* landscape on wide screens; a transposed portrait swaps in on mobile */
  .tm-view.landscape .tm-svg { min-width: 760px; }
  .tm-view.portrait { display: none; }
  .tm-view.portrait .tm-svg { max-width: 460px; margin-inline: auto; }
  @media (max-width: 40rem) {
    .tm-view.landscape { display: none; }
    .tm-view.portrait { display: block; }
  }

  .tm-contour { fill: none; stroke: var(--contour); stroke-width: 0.6; opacity: 0.28; }
  .tm-contour.index { stroke-width: 0.9; opacity: 0.4; }

  /* the drainage network — where the watershed collects */
  .tm-stream {
    fill: none; stroke: var(--water); stroke-linecap: round;
    stroke-linejoin: round; opacity: 0.55;
  }

  /* trails — green, meandering; thin ones dashed like secondary routes */
  .tm-edge {
    fill: none; stroke: var(--trail); stroke-linecap: round;
    opacity: 0; transition: opacity 0.12s;
  }
  .tm-edge:not(.bb) { stroke-dasharray: 2 3; }
  .tm-edge.bb { opacity: 0.4; }
  .tm-svg.tm-focused .tm-edge { opacity: 0.06; }
  .tm-svg.tm-focused .tm-edge.hot {
    opacity: 0.95; stroke: var(--red); stroke-dasharray: none;
  }

  /* trailheads */
  .tm-node { cursor: pointer; transition: opacity 0.12s; }
  .tm-node circle {
    fill: var(--ink); stroke: #f7f1e3; stroke-width: 1.2;
    transition: fill 0.12s, stroke 0.12s;
  }
  .ax-curated circle { fill: var(--trail-deep); }

  .tm-label {
    font-family: var(--mono); font-size: 9px; fill: var(--trail-deep);
    opacity: 0; pointer-events: none; paint-order: stroke;
    stroke: #f7f1e3; stroke-width: 2.6px;
  }
  .tm-node.anchor .tm-label { opacity: 0.7; }

  .tm-svg.tm-focused .tm-node { opacity: 0.2; }
  .tm-svg.tm-focused .tm-node.hot,
  .tm-svg.tm-focused .tm-node.near { opacity: 1; }
  .tm-svg.tm-focused .tm-node.hot .tm-label,
  .tm-svg.tm-focused .tm-node.near .tm-label { opacity: 0.95; }
  .tm-node.hot circle { fill: var(--red); stroke: #f7f1e3; stroke-width: 2; }

  .tm-foot {
    margin: 1rem 0 0; font-family: var(--mono); font-size: 0.68rem;
    opacity: 0.55; line-height: 1.7;
  }
  .tm-foot a { color: var(--red); text-decoration: none; }
  .tm-foot a:hover { text-decoration: underline; }

  @media (max-width: 40rem) {
    .atlas-row { grid-template-columns: 1fr; gap: 0.3rem; }
  }
</style>

<script>
  // Trail map interactivity: hover/focus a station to light its crossings and
  // the threads it meets. No framework; layout is baked at build time.
  for (const svg of document.querySelectorAll('.tm-svg')) {
    const nodes = [...svg.querySelectorAll('.tm-node')]
    const edges = [...svg.querySelectorAll('.tm-edge')]
    const adj = new Map()
    for (const e of edges) {
      const a = e.dataset.a
      const b = e.dataset.b
      if (!adj.has(a)) adj.set(a, new Set())
      if (!adj.has(b)) adj.set(b, new Set())
      adj.get(a).add(b)
      adj.get(b).add(a)
    }
    const focus = slug => {
      const near = adj.get(slug) || new Set()
      svg.classList.add('tm-focused')
      for (const n of nodes) {
        const s = n.dataset.slug
        n.classList.toggle('hot', s === slug)
        n.classList.toggle('near', near.has(s))
      }
      for (const e of edges) {
        e.classList.toggle('hot', e.dataset.a === slug || e.dataset.b === slug)
      }
    }
    const clear = () => {
      svg.classList.remove('tm-focused')
      for (const n of nodes) n.classList.remove('hot', 'near')
      for (const e of edges) e.classList.remove('hot')
    }
    for (const n of nodes) {
      const slug = n.dataset.slug
      n.addEventListener('mouseenter', () => focus(slug))
      n.addEventListener('mouseleave', clear)
      n.addEventListener('focus', () => focus(slug))
      n.addEventListener('blur', clear)
    }
  }
</script>
