---
import Base from '../../layouts/Base.astro'
import fs from 'node:fs'
import { resolve } from 'path'
import yaml from 'js-yaml'
import { loadCorpus } from '../../lib/load-corpus.mjs'
import { loadThreads } from '../../lib/threads.mjs'
import { buildMap } from '../../lib/textscape-engine.mjs'

// The atlas — the map of the rhizome. The interactive map is rendered by the
// shared `textscape` engine (vendored from claude-memory/tools/textscape):
// threads are laid out by the commons they share, a watershed is eroded from
// that density, and trails route the low way across it. Pan/zoom, decluttering
// labels, hover to trace crossings, click a theme for its gestures. Below it,
// the field — every gesture in the river with thread membership overlaid.

const corpus = loadCorpus(resolve('.'))
const river = yaml.load(fs.readFileSync(resolve('src/content/manifests/the-river.manifest.yml'), 'utf8'))

const rawThreads = loadThreads()
// theme graph for the engine: a thread is a "theme", its gestures are its "units"
const threads = rawThreads.map(t => ({ id: t.slug, label: t.h1 || t.title, units: t.gestures || [] }))
// provenance: gesture id -> short label for the click panel
const unitText = {}
for (const id of Object.keys(corpus.gestures || {})) unitText[id] = corpus.gestures[id]?.title || id

const { map, body, css, clientJs } = buildMap(threads, {
  seed: 7,
  units: unitText,
  meta: { title: 'The map of the rhizome' },
})

// legend (kept) + the field heatmap (kept)
const legend = rawThreads.slice().sort((a, b) => (a.h1 || a.title).localeCompare(b.h1 || b.title))
const onThreads = {}
for (const t of rawThreads) for (const id of t.gestures) (onThreads[id] ||= []).push(t)
const bySlug = Object.fromEntries(corpus.plateaus.map(p => [p.slug, p]))
const rows = (river.sources || [])
  .map(slug => {
    const ch = bySlug[slug]
    if (!ch) return null
    return {
      slug,
      title: ch.title || slug,
      cells: ch.gestures.map(id => {
        const on = onThreads[id] || []
        return { id, title: corpus.gestures[id]?.title || id, threads: on.map(t => t.h1 || t.title), n: on.length }
      }),
    }
  })
  .filter(Boolean)

const gestureCount = rows.reduce((n, r) => n + r.cells.length, 0)
const memberCount = rows.reduce((n, r) => n + r.cells.filter(c => c.n > 0).length, 0)
const nodeCount = Object.values(onThreads).filter(a => a.length > 1).length
---
<Base
  title="Atlas — Power Explained"
  description="The map of the rhizome: every thread laid out by the commons it shares, as an eroded watershed you can walk."
>
  <div class="article-wrap atlas-wrap">
    <p class="book-nav">
      <a href="/book">← The Book</a>
      <span class="book-nav-sep">·</span>
      <a href="/book/path">Threads</a>
      <span class="book-nav-sep">·</span>
      <span>Experimental · the composable river</span>
    </p>

    <header class="atlas-head">
      <p class="atlas-label">Atlas</p>
      <h1>The map of the rhizome</h1>
      <p class="atlas-dek">
        Every thread is a station, placed by the commons it shares — threads that
        pass through the same gestures pull together into clusters. The land is a
        watershed eroded from that density; each trail takes the low way across it.
        <strong>Drag to pan, scroll to zoom, hover to trace a thread's crossings,
        click a station for its gestures.</strong>
      </p>
      <p class="atlas-counts">
        {map.nodes.length} threads · {map.edges.length} crossings · {gestureCount} gestures
        · {memberCount} on a thread · {nodeCount} rhizome nodes
      </p>
    </header>

    <Fragment set:html={body} />

    <details class="atlas-legend-wrap">
      <summary>All {legend.length} threads</summary>
      <ul class="atlas-legend">
        {legend.map(t => (
          <li>
            <a href={`/book/path/${t.slug}`}>{t.h1 || t.title}</a>
            <span class="legend-count">{t.gestures.length}</span>
          </li>
        ))}
      </ul>
    </details>

    <section class="atlas-field-sec">
      <h2 class="field-h">The field</h2>
      <p class="field-note">
        Every gesture in the river, chapter by chapter, in canonical order. An
        outlined cell sits on a thread; a filled cell is a node — a gesture where
        threads cross.
      </p>
      <div class="atlas-field">
        {rows.map(r => (
          <div class="atlas-row">
            <a class="atlas-chapter" href={`/book/${r.slug}`}>{r.title}</a>
            <div class="atlas-cells">
              {r.cells.map(c => (
                <span
                  class={`cell${c.n > 1 ? ' node' : c.n === 1 ? ' member' : ''}`}
                  title={`${c.id} · ${c.title}${c.threads.length ? ` · ${c.threads.join(' / ')}` : ''}`}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <p class="atlas-foot">
      A thread is an ordering of gestures the book already holds; the map is the
      field they are drawn from, laid out by what they share.
      <a href="/book/river">Read the whole river →</a>
    </p>
  </div>
</Base>

<style is:global set:html={css}></style>

<style>
  .atlas-wrap { max-width: 60rem; }
  .book-nav {
    font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.1em;
    text-transform: uppercase; opacity: 0.4; margin-bottom: 2rem;
    display: flex; gap: 0.5rem; align-items: center;
  }
  .book-nav a { color: inherit; text-decoration: none; }
  .book-nav a:hover { color: var(--red); }
  .book-nav-sep { opacity: 0.4; }

  .atlas-head { margin: 0 0 1.5rem; }
  .atlas-label {
    font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em;
    text-transform: uppercase; opacity: 0.45; margin-bottom: 0.75rem;
  }
  .atlas-dek { font-size: 0.95rem; line-height: 1.7; opacity: 0.78; max-width: 40rem; margin-top: 1rem; }
  .atlas-dek strong { font-weight: 600; opacity: 0.95; }
  .atlas-counts {
    font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.06em;
    opacity: 0.5; margin-top: 1rem;
  }

  /* give the interactive map a comfortable viewport */
  .atlas-wrap :global(.ts-map) { margin: 0 0 1.5rem; }

  .atlas-legend-wrap { margin: 0 0 2.5rem; }
  .atlas-legend-wrap summary {
    font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.06em;
    text-transform: uppercase; opacity: 0.55; cursor: pointer;
  }
  .atlas-legend {
    list-style: none; padding: 0.75rem 0 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: 0.4rem 1.25rem;
  }
  .atlas-legend a { color: var(--ink); text-decoration: none; font-size: 0.85rem; }
  .atlas-legend a:hover { color: var(--red); }
  .legend-count { font-family: var(--mono); font-size: 0.6rem; opacity: 0.45; margin-left: 0.3rem; }

  .atlas-field-sec { margin: 0 0 2rem; padding-top: 1.5rem; border-top: 1px solid var(--rule); }
  .field-h { font-family: var(--display); font-size: 1.4rem; font-weight: 600; margin: 0 0 0.4rem; }
  .field-note { font-size: 0.9rem; line-height: 1.6; opacity: 0.65; max-width: 36rem; margin: 0 0 1.25rem; }
  .atlas-field { display: grid; gap: 0.9rem; }
  .atlas-row { display: grid; grid-template-columns: 11rem 1fr; gap: 1rem; align-items: start; }
  .atlas-chapter {
    font-family: var(--mono); font-size: 0.65rem; line-height: 1.5; letter-spacing: 0.03em;
    color: var(--ink); opacity: 0.65; text-decoration: none; padding-top: 0.05rem;
  }
  .atlas-chapter:hover { color: var(--red); opacity: 1; }
  .atlas-cells { display: flex; flex-wrap: wrap; gap: 3px; }
  .cell { width: 9px; height: 9px; border-radius: 1px; background: rgba(var(--ink-rgb), 0.13); }
  .cell.member { background: var(--paper-mid); box-shadow: inset 0 0 0 1.5px var(--red); }
  .cell.node { background: var(--red); }

  .atlas-foot {
    margin: 3rem 0 2rem; font-family: var(--mono); font-size: 0.7rem; opacity: 0.5; line-height: 1.7;
  }
  .atlas-foot a { color: var(--red); text-decoration: none; }
  .atlas-foot a:hover { text-decoration: underline; }

  @media (max-width: 40rem) {
    .atlas-row { grid-template-columns: 1fr; gap: 0.3rem; }
  }
</style>

<script set:html={clientJs + "\ndocument.querySelectorAll('.ts-map').forEach(textscapeMount);"} is:inline></script>
