---
import Base from '../../layouts/Base.astro'
import { resolve } from 'path'
import { composePlateauBody } from '../../lib/composePlateauBody.mjs'
import { md } from '../../lib/markdown.mjs'

const body = composePlateauBody(resolve('src/content/book/prologue.md'))
---
<Base title="Prologue: Look Up" description="What connects the rent that keeps going up, the highway that cut the neighborhood in half, the hospital bill, the platform. There is one pattern.">
  <div class="hero">
    <div class="hero-inner">
      <p class="book-nav"><a href="/book">← The Book</a></p>
      <p class="book-label">Prologue</p>
      <h1>Look Up</h1>
    </div>
  </div>

  <div class="article-wrap">
    <div class="body-text prologue-body" data-pagefind-body set:html={md(body)} />
    <nav class="article-prev-next">
      <div class="prev-next-inner">
        <span />
        <a href="/book/chapter-1" class="prev-next-link next-link">
          <span class="prev-next-label">Next →</span>
          <span class="prev-next-title">Chapter 1: Why Your City Doesn't Work</span>
        </a>
      </div>
    </nav>
  </div>
</Base>

<style>
  .book-nav { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.4; margin-bottom: 1.5rem; }
  .book-nav a { color: inherit; text-decoration: none; }
  .book-nav a:hover { color: var(--red); }
  .book-label { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.45; margin-bottom: 0.75rem; }
  .prologue-body :global(hr.section-break) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 3rem 0;
  }
  .prologue-body :global(p:first-child) {
    font-size: 1.05rem;
  }
</style>
