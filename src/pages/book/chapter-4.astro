---
import Base from '../../layouts/Base.astro'
import Doors from '../../components/Doors.astro'
import { readFileSync, readdirSync, existsSync } from 'fs'
import { resolve, join } from 'path'

// === Read chapter frontmatter and the gesture manifest ===
const chapterPath = resolve('src/content/book/chapter-4.md')
const raw = readFileSync(chapterPath, 'utf8')
const fmEnd = raw.indexOf('\n---\n', 4)
const yaml = raw.slice(4, fmEnd)
const trailingBody = raw.slice(fmEnd + 5).trim()  // framing prose if any

// Tiny inline YAML list extractor (top-level lists only)
function extractList(y, key) {
  const lines = y.split('\n')
  const start = lines.findIndex(l => new RegExp('^' + key + ':\\s*(#.*)?$').test(l))
  if (start === -1) return null
  const out = []
  for (let i = start + 1; i < lines.length; i++) {
    const line = lines[i]
    if (line.trim() === '' || line.trim().startsWith('#')) continue
    if (!line.startsWith(' ')) break
    const m = line.match(/^\s+-\s+(.+?)(?:\s+#.*)?$/)
    if (m) out.push(m[1].trim())
    else if (!line.match(/^\s+#/)) break
  }
  return out
}

const gestureIds = extractList(yaml, 'gestures') || []
const separators = extractList(yaml, 'separators') || []

// === Read each gesture's body and concatenate per separators ===
function readGestureBody(plateauId, gestureId) {
  const dir = resolve('src/content/gestures', plateauId)
  if (!existsSync(dir)) throw new Error(`Missing gesture dir: ${dir}`)
  const num = gestureId.split('-').pop()
  const files = readdirSync(dir)
  const match = files.find(f => f.startsWith(num + '-'))
  if (!match) throw new Error(`Gesture not found: ${gestureId}`)
  const text = readFileSync(join(dir, match), 'utf8')
  const e = text.indexOf('\n---\n', 4)
  return text.slice(e + 5).replace(/^\n+/, '').replace(/\n+$/, '')
}

let body
if (gestureIds.length > 0) {
  // Plateau composed from gestures
  const plateauId = 'P-' + gestureIds[0].split('-')[1]
  const parts = []
  gestureIds.forEach((gid, i) => {
    parts.push(readGestureBody(plateauId, gid))
    if (i < gestureIds.length - 1) {
      const sep = separators[i] || 'paragraph'
      parts.push(sep === 'section' ? '\n\n---\n\n' : '\n\n')
    }
  })
  body = parts.join('')
  if (trailingBody) body += '\n\n' + trailingBody
} else {
  // Legacy: body inline (chapters not yet refactored to gestures)
  body = trailingBody
}

function md(text) {
  return text
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/_(.+?)_/g, '<em>$1</em>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    .replace(/^---$/gm, '<hr class="section-break" />')
    .split(/\n\n+/)
    .map(b => {
      b = b.trim()
      if (!b) return ''
      if (b.startsWith('<h') || b.startsWith('<hr')) return b
      if (b.startsWith('*') && b.endsWith('*') && !b.startsWith('**'))
        return `<p class="chapter-coda">${b.slice(1,-1)}</p>`
      return `<p>${b.replace(/\n/g, ' ')}</p>`
    })
    .filter(Boolean)
    .join('\n')
}
---
<Base title="Chapter 4: Nobody Asked Him To" description="Arizmendi on his bike. Eight farmers in black blouses. A fridge on a Brooklyn sidewalk. The commons is present tense.">
  <div class="hero">
    <div class="hero-inner">
      <p class="book-nav">
        <a href="/book">← The Book</a>
        <span class="book-nav-sep">·</span>
        <span>Part II: The Proof</span>
      </p>
      <p class="book-label">Chapter 4</p>
      <h1>Nobody Asked Him To</h1>
    </div>
  </div>
  <div class="article-wrap">
    <div class="body-text chapter-body" data-pagefind-body set:html={md(body)} />

    <Doors slug="chapter-4" />

    <nav class="article-prev-next">
      <div class="prev-next-inner">
        <a href="/book/interlude-washington" class="prev-next-link">
          <span class="prev-next-label">← Previous on the highway</span>
          <span class="prev-next-title">Interlude: Counter-Hegemony Without the Word</span>
        </a>
        <a href="/book/chapter-5" class="prev-next-link next-link">
          <span class="prev-next-label">Highway forward →</span>
          <span class="prev-next-title">Chapter 5: The Outside</span>
        </a>
      </div>
    </nav>
  </div>
</Base>
<style>
  .book-nav { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.4; margin-bottom: 1.5rem; display: flex; gap: 0.5rem; align-items: center; }
  .book-nav a { color: inherit; text-decoration: none; }
  .book-nav a:hover { color: var(--red); }
  .book-nav-sep { opacity: 0.4; }
  .book-label { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.45; margin-bottom: 0.75rem; }
  .chapter-body :global(hr.section-break) { border: none; border-top: 1px solid var(--rule); margin: 3rem 0; }
  .chapter-body :global(.chapter-coda) { font-family: var(--mono); font-size: 0.8rem; line-height: 1.7; color: rgba(var(--ink-rgb), 0.6); margin-top: 3rem; padding: 1.5rem; border: 1px solid var(--rule); border-radius: 2px; background: var(--paper-mid); }
</style>
