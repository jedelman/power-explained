---
import Base from '../../layouts/Base.astro'
import { resolve } from 'path'
import { composePlateauBody } from '../../lib/composePlateauBody.mjs'

// Parse the overture markdown manually — it's not in the content collection
const body = composePlateauBody(resolve('src/content/book/overture.md'))

// Basic markdown → html for the overture
function md(text) {
  return text
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    .replace(/^---$/gm, '<hr class="section-break" />')
    .split(/\n\n+/)
    .map(b => {
      b = b.trim()
      if (!b) return ''
      if (b.startsWith('<h') || b.startsWith('<hr')) return b
      return `<p>${b.replace(/\n/g, ' ')}</p>`
    })
    .filter(Boolean)
    .join('\n')
}
---
<Base title="How to Become a Wizard and Save the World" description="What a wizard is, what the enclosure took, and the craft of getting it back. The register before the world.">
  <div class="hero">
    <div class="hero-inner">
      <p class="book-nav"><a href="/book">← The Book</a></p>
      <p class="book-label">Overture</p>
      <h1>How to Become a Wizard and Save the World</h1>
    </div>
  </div>

  <div class="article-wrap">
    <div class="body-text prologue-body" data-pagefind-body set:html={md(body)} />
    <nav class="article-prev-next">
      <div class="prev-next-inner">
        <span />
        <a href="/book/prologue" class="prev-next-link next-link">
          <span class="prev-next-label">Next →</span>
          <span class="prev-next-title">Prologue: Look Up</span>
        </a>
      </div>
    </nav>
  </div>
</Base>

<style>
  .book-nav { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.4; margin-bottom: 1.5rem; }
  .book-nav a { color: inherit; text-decoration: none; }
  .book-nav a:hover { color: var(--red); }
  .book-label { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.45; margin-bottom: 0.75rem; }
  .prologue-body :global(hr.section-break) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 3rem 0;
  }
  .prologue-body :global(p:first-child) {
    font-size: 1.05rem;
  }
</style>
