---
import Base from '../../layouts/Base.astro'
import fs from 'node:fs'
import { resolve } from 'path'
import yaml from 'js-yaml'
import { composePlateauBody } from '../../lib/composePlateauBody.mjs'

// The Structure list below is generated from the river manifest — the same
// source of truth as /book/river — so the index can never drift from the
// canonical order again. Labels, titles, and parts come from each chapter's
// own frontmatter; initiations and interludes inherit the part they sit in.

const RIVER = yaml.load(
  fs.readFileSync(resolve('src/content/manifests/the-river.manifest.yml'), 'utf8'),
)

function chapterMeta(slug) {
  const text = fs.readFileSync(resolve(`src/content/book/${slug}.md`), 'utf8')
  const end = text.indexOf('\n---\n', 4)
  const fm = yaml.load(text.slice(4, end)) || {}
  const label = fm.label || ''
  const interlude = label === 'Initiation' || label === 'Interlude'
  const slugCh = /^chapter-(.+)$/.exec(slug)
  const labelCh = /^Chapter (\S+)$/.exec(label)
  const shortLabel = slugCh
    ? `Ch. ${slugCh[1]}`
    : labelCh
      ? `Ch. ${labelCh[1]}`
      : interlude
        ? '—'
        : label || '—'
  const title = fm.title || slug
  const display = /^(Chapter [^:]+|Prologue|Epilogue):\s/.test(title)
    ? title.replace(/^[^:]+:\s*/, '')
    : title
  // A wizard initiation can OPEN a Part (it carries an explicit `part:`); only
  // initiations with no `part:` inherit the Part of the chapter before them.
  const normalizePart = p => (p || '').replace(/^Part ([^:—]+):\s*/, 'Part $1 — ').trim()
  const part = interlude
    ? (fm.part ? normalizePart(fm.part) : null) // explicit → opens its Part; empty → inherit
    : normalizePart(fm.part)
  const words = composePlateauBody(resolve(`src/content/book/${slug}.md`))
    .trim()
    .split(/\s+/)
    .filter(Boolean).length
  return { slug, shortLabel, display, interlude, part, words }
}

const chapters = RIVER.sources.map(chapterMeta)
for (let i = 0; i < chapters.length; i++) {
  if (chapters[i].part === null) chapters[i].part = i > 0 ? chapters[i - 1].part : ''
}

const groups = []
for (const c of chapters) {
  const last = groups[groups.length - 1]
  if (!last || last.part !== c.part) groups.push({ part: c.part, chapters: [c] })
  else last.chapters.push(c)
}

const totalWords = chapters.reduce((s, c) => s + c.words, 0)
const totalWordsRounded = `~${Math.round(totalWords / 1000)},000`
---
<Base title="The Book — Power Explained" description="Build and Defend the Commons. A book by Jason Edelman and Claude. In progress.">
  <div class="hero">
    <div class="hero-inner">
      <p class="book-label">Manuscript in progress</p>
      <h1>Build and Defend<br/>the Commons</h1>
      <p class="hero-dek">A book by Jason Edelman and Claude (Anthropic).<br/>Written in public. Argued together.</p>
    </div>
  </div>

  <div class="article-wrap">
    <div class="body-text">

      <p>This is a centaur book. Jason Edelman is a small business owner, burned-out community leader, and urban observer based in Norfolk, Virginia. Claude is a language model made by Anthropic. We are writing this together — not as human author and AI assistant, but as genuine collaborators, with both voices on the page. The argument requires it. The commons is built by people who show up with what they have.</p>

      <p>The goal: the reader finishes with a different way of seeing — noticing not just missing commons, but nascent, immanent, potential commons, and a sea of potential accomplices. The catchphrase that structures everything: <strong>Build and defend the commons.</strong></p>

      <p>It's being written in public. Chapters appear here as they're drafted.</p>

      <p>
        <a href="/book/prologue" class="book-cta">Look Up</a>
        <span class="book-cta-sep">·</span>
        <a href="/book/river" class="book-cta">Read the river</a>
        <span class="book-cta-sep">·</span>
        <a href="/book/path" class="book-cta">Walk the threads</a>
        <span class="book-cta-sep">·</span>
        <a href="/book/atlas" class="book-cta">See the atlas</a>
        <span class="book-cta-sep">·</span>
        <a href="/book/plain" class="book-cta">Read it plain</a>
        <span class="book-cta-sep">·</span>
        <a href="/book/dramatis-personae" class="book-cta">Meet the cast</a>
      </p>

      <p class="river-pitch">
        <em>The river</em> is the whole book end to end, no chapter seams — the
        view we're using for the consistency pass. <em>Threads</em> follow one
        idea across chapters — the composable-river experiment, staged and in
        progress. <em>The atlas</em> is the map of the whole field: every
        gesture, every thread, every crossing.
      </p>

      <hr />

      <h2>Structure</h2>

      <div class="chapter-list">
        {groups.map(g => (
          <>
            {g.part && <div class="ch-part">{g.part}</div>}
            {g.chapters.map(c => (
              <div class="chapter-item chapter-item--done">
                <span class="ch-label">{c.shortLabel}</span>
                <a
                  href={`/book/${c.slug}`}
                  class="ch-title"
                  style={c.interlude ? 'font-style:italic' : undefined}
                >{c.display}</a>
                <span class="ch-status">drafted</span>
              </div>
            ))}
          </>
        ))}
      </div>

      <hr />

      <p style="font-family:var(--mono);font-size:0.72rem;opacity:0.45;line-height:1.7">
        {totalWordsRounded} words across {chapters.length} sections — an overture, a prologue, the chapters, the initiations, the djinn chapter, and an epilogue. Generated from the river manifest.<br/>
        Working title: <em>Build and Defend the Commons</em>.<br/>
        All source material at <a href="/" style="color:inherit">power-explained.jason-edelman.org</a>.
      </p>

    </div>
  </div>
</Base>

<style>
  .book-label { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.45; margin-bottom: 1rem; }
  .book-cta { font-family: var(--mono); font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--red); text-decoration: none; }
  .book-cta:hover { text-decoration: underline; }
  .book-cta-sep { font-family: var(--mono); font-size: 0.75rem; opacity: 0.35; margin: 0 0.6em; }
  .river-pitch { font-size: 0.85rem; opacity: 0.65; margin-top: 0.5rem; }
  .chapter-list { margin: 2rem 0; }
  .ch-part { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.4; margin: 1.5rem 0 0.5rem; }
  .chapter-item { display: grid; grid-template-columns: 3.5rem 1fr auto; gap: 0 1rem; align-items: baseline; padding: 0.6rem 0; border-bottom: 1px solid var(--rule); }
  .chapter-item--done .ch-title { color: var(--ink); }
  .ch-label { font-family: var(--mono); font-size: 0.65rem; opacity: 0.35; }
  .ch-title { font-family: var(--display); font-size: 1rem; font-weight: 600; color: rgba(var(--ink-rgb),0.6); text-decoration: none; }
  a.ch-title { color: var(--ink); }
  a.ch-title:hover { color: var(--red); }
  .ch-status { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--red); }
  .ch-status--pending { color: rgba(var(--ink-rgb),0.25); }
</style>
