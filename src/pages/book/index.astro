<style>
  .book-label { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.45; margin-bottom: 1rem; }
  .book-cta { font-family: var(--mono); font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--red); text-decoration: none; }
  .book-cta:hover { text-decoration: underline; }
  .book-cta-sep { font-family: var(--mono); font-size: 0.75rem; opacity: 0.35; margin: 0 0.6em; }
  .river-pitch { font-size: 0.85rem; opacity: 0.65; margin-top: 0.5rem; }
  .chapter-list { margin: 2rem 0; }
  .ch-part { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.4; margin: 1.5rem 0 0.5rem; }
  .chapter-item { display: grid; grid-template-columns: 3.5rem 1fr auto; gap: 0 1rem; align-items: baseline; padding: 0.6rem 0; border-bottom: 1px solid var(--rule); }
  .chapter-item--done .ch-title { color: var(--ink); }
  .ch-label { font-family: var(--mono); font-size: 0.65rem; opacity: 0.35; }
  .ch-title { font-family: var(--display); font-size: 1rem; font-weight: 600; color: rgba(var(--ink-rgb),0.6); text-decoration: none; }
  a.ch-title { color: var(--ink); }
  a.ch-title:hover { color: var(--red); }
  .ch-status { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--red); }
  .ch-status--pending { color: rgba(var(--ink-rgb),0.25); }
</style>
